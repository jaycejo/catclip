# CLIPBOARD
#
# Stored as an array — no eval. Array dispatch is injection-proof.
# ==============================================================================

CLIPBOARD_CMD=()

detect_clipboard_cmd() {
  case "$PLATFORM" in
    macos)
      command -v pbcopy &>/dev/null && { CLIPBOARD_CMD=(pbcopy); return 0; } ;;
    wsl)
      command -v clip.exe &>/dev/null && { CLIPBOARD_CMD=(clip.exe); return 0; } ;;
  esac

  local is_wayland=false
  [[ "${XDG_SESSION_TYPE:-}" == "wayland" || -n "${WAYLAND_DISPLAY:-}" ]] && is_wayland=true

  if [[ "$is_wayland" == true ]]; then
    command -v wl-copy &>/dev/null && { CLIPBOARD_CMD=(wl-copy); return 0; }
    command -v xclip &>/dev/null  && { CLIPBOARD_CMD=(xclip -selection clipboard); return 0; }
    command -v xsel &>/dev/null   && { CLIPBOARD_CMD=(xsel --clipboard --input); return 0; }
  else
    command -v xclip &>/dev/null && { CLIPBOARD_CMD=(xclip -selection clipboard); return 0; }
    command -v xsel &>/dev/null  && { CLIPBOARD_CMD=(xsel --clipboard --input); return 0; }
  fi
  return 1
}

print_clipboard_install_hint() {
  case "$PLATFORM" in
    macos) printf "  Ensure pbcopy is in PATH (ships with macOS).\n" >&2 ;;
    wsl)   printf "  Ensure clip.exe is available (ships with WSL).\n" >&2 ;;
    linux)
      if [[ "${XDG_SESSION_TYPE:-}" == "wayland" || -n "${WAYLAND_DISPLAY:-}" ]]; then
        printf "  Wayland detected. Install wl-clipboard:\n" >&2
        printf "    sudo apt install wl-clipboard    ${DIM}# Debian/Ubuntu${RESET}\n" >&2
        printf "    sudo pacman -S wl-clipboard      ${DIM}# Arch${RESET}\n" >&2
      else
        printf "  X11 detected. Install xclip:\n" >&2
        printf "    sudo apt install xclip           ${DIM}# Debian/Ubuntu${RESET}\n" >&2
        printf "    sudo pacman -S xclip             ${DIM}# Arch${RESET}\n" >&2
      fi ;;
  esac
}

# ==============================================================================
# SCOPE STORAGE & EVALUATION
#
# [Point 1] Parallel arrays indexed by scope number instead of string packing.
# --include removes rules, --exclude adds rules. Both modify the in-memory blocklist before discovery.
# ==============================================================================

# Parallel arrays — one entry per scope.
SCOPE_TARGETS=()
SCOPE_CHANGED=()
SCOPE_NO_IGNORE=()
SCOPE_ONLY=()
SCOPE_SKIP=()
SCOPE_FORCE=()
SCOPE_CONTAINS=()
SCOPE_SNIPPET=()
SCOPE_STAGED=()
SCOPE_UNSTAGED=()
SCOPE_UNTRACKED=()
SCOPE_DIFF=()
SCOPE_FILTER_USE_IGNORE=()
SCOPE_FILTER_USE_ONLY=()
SCOPE_FILTER_FILE_REGEX=()
SCOPE_FILTER_DIR_REGEX=()
SCOPE_FILTER_ONLY_REGEX=()
FILTER_CACHE_KEYS=()
FILTER_CACHE_USE_IGNORE=()
FILTER_CACHE_USE_ONLY=()
FILTER_CACHE_FILE_REGEX=()
FILTER_CACHE_DIR_REGEX=()
FILTER_CACHE_ONLY_REGEX=()
HAD_FUZZY_FAIL=false

add_scope() {
  SCOPE_TARGETS+=(   "$1"  )
  SCOPE_CHANGED+=(   "$2"  )
  SCOPE_NO_IGNORE+=( "$3"  )
  SCOPE_ONLY+=(      "$4"  )
  SCOPE_SKIP+=(      "$5"  )
  SCOPE_FORCE+=(     "$6"  )
  SCOPE_CONTAINS+=(  "$7"  )
  SCOPE_SNIPPET+=(   "$8"  )
  SCOPE_STAGED+=(    "$9"   )
  SCOPE_UNSTAGED+=(  "${10}" )
  SCOPE_UNTRACKED+=( "${11}" )
  SCOPE_DIFF+=(      "${12}" )
}


  # Prefer inlining ${#SCOPE_TARGETS[@]} at call sites to avoid
  # subshell forks. This function exists only for the few places
  # where a command substitution is unavoidable (e.g. local assignment).
scope_count() {
  echo "${#SCOPE_TARGETS[@]}"
}

# Compile a stream of shell globs into one-regex-per-line files that awk can
# load quickly for each scope. This keeps the hot filter path focused on path
# matching instead of repeatedly translating patterns.
compile_globs_to_regex_stream() {
  local mode="$1"
  awk -v mode="$mode" '
  # Supported glob subset intentionally mirrors the old bash case matcher:
  #   *   ?   [...]
  #
  # Known limitation: escaped literals outside character classes (for example
  # "\*.log" to match a literal asterisk) are not handled with full bash-glob
  # fidelity. That keeps the hot path fast, and those patterns are not used by
  # the default .hiss or normal CLI usage.
  function glob_to_ere(glob,    i, c, out, in_class, class_first) {
    out = ""
    in_class = 0
    class_first = 0

    for (i = 1; i <= length(glob); i++) {
      c = substr(glob, i, 1)
      if (in_class) {
        if (c == "]" && class_first == 0) {
          out = out c
          in_class = 0
          continue
        }
        if (class_first == 1 && c == "!") {
          out = out "^"
        } else if (c == "\\") {
          out = out "\\\\"
        } else {
          out = out c
        }
        class_first = 0
        continue
      }

      if (c == "*") out = out ".*"
      else if (c == "?") out = out "."
      else if (c == "[") {
        out = out c
        in_class = 1
        class_first = 1
      } else if (c ~ /[][(){}.+^$|\\]/) {
        out = out "\\" c
      } else {
        out = out c
      }
    }

    return out
  }

  {
    if ($0 == "") next
    regex = glob_to_ere($0)
    if (mode == "dir") print "(^|.*/)" regex "/.*"
    else print "^" regex "$"
  }'
}

build_filter_cache_key() {
  local is_no_ignore="$1"
  local only_csv="$2"
  local key="no_ignore=$is_no_ignore"$'\n'"only=$only_csv"$'\n'
  local p d

  key="${key}ignore_files"$'\n'
  for p in ${ignore_files[@]+"${ignore_files[@]}"}; do
    key="${key}${p}"$'\n'
  done
  key="${key}ignore_dirs"$'\n'
  for d in ${ignore_dirs[@]+"${ignore_dirs[@]}"}; do
    key="${key}${d}"$'\n'
  done

  printf '%s' "$key"
}

find_filter_cache_index() {
  local key="$1"
  local i
  for (( i = 0; i < ${#FILTER_CACHE_KEYS[@]}; i++ )); do
    [[ "${FILTER_CACHE_KEYS[$i]}" == "$key" ]] && { echo "$i"; return 0; }
  done
  echo "-1"
}

prepare_scope_filter_cache() {
  local idx="$1"
  local is_no_ignore="$2"
  local only_csv="$3"
  local cache_key cache_idx
  cache_key=$(build_filter_cache_key "$is_no_ignore" "$only_csv")
  cache_idx=$(find_filter_cache_index "$cache_key")

  if [[ "$cache_idx" != "-1" ]]; then
    SCOPE_FILTER_USE_IGNORE[$idx]="${FILTER_CACHE_USE_IGNORE[$cache_idx]}"
    SCOPE_FILTER_USE_ONLY[$idx]="${FILTER_CACHE_USE_ONLY[$cache_idx]}"
    SCOPE_FILTER_FILE_REGEX[$idx]="${FILTER_CACHE_FILE_REGEX[$cache_idx]}"
    SCOPE_FILTER_DIR_REGEX[$idx]="${FILTER_CACHE_DIR_REGEX[$cache_idx]}"
    SCOPE_FILTER_ONLY_REGEX[$idx]="${FILTER_CACHE_ONLY_REGEX[$cache_idx]}"
    return 0
  fi

  local use_ignore=false use_only=false
  local file_regex="" dir_regex="" only_regex=""
  local only_pats=()

  if [[ "$is_no_ignore" != true ]] && (( ${#ignore_files[@]} > 0 || ${#ignore_dirs[@]} > 0 )); then
    use_ignore=true
    if (( ${#ignore_files[@]} > 0 )); then
      file_regex=$(mktmp)
      printf '%s\n' "${ignore_files[@]}" | compile_globs_to_regex_stream "file" > "$file_regex"
    fi
    if (( ${#ignore_dirs[@]} > 0 )); then
      dir_regex=$(mktmp)
      printf '%s\n' "${ignore_dirs[@]}" | compile_globs_to_regex_stream "dir" > "$dir_regex"
    fi
  fi

  if [[ -n "$only_csv" ]]; then
    IFS=',' read -ra only_pats <<< "$only_csv"
    if (( ${#only_pats[@]} > 0 )); then
      use_only=true
      only_regex=$(mktmp)
      printf '%s\n' "${only_pats[@]}" | compile_globs_to_regex_stream "only" > "$only_regex"
    fi
  fi

  cache_idx="${#FILTER_CACHE_KEYS[@]}"
  FILTER_CACHE_KEYS+=( "$cache_key" )
  FILTER_CACHE_USE_IGNORE+=( "$use_ignore" )
  FILTER_CACHE_USE_ONLY+=( "$use_only" )
  FILTER_CACHE_FILE_REGEX+=( "$file_regex" )
  FILTER_CACHE_DIR_REGEX+=( "$dir_regex" )
  FILTER_CACHE_ONLY_REGEX+=( "$only_regex" )

  SCOPE_FILTER_USE_IGNORE[$idx]="$use_ignore"
  SCOPE_FILTER_USE_ONLY[$idx]="$use_only"
  SCOPE_FILTER_FILE_REGEX[$idx]="$file_regex"
  SCOPE_FILTER_DIR_REGEX[$idx]="$dir_regex"
  SCOPE_FILTER_ONLY_REGEX[$idx]="$only_regex"
}

# Single-pass filter: is_ignored + --only.
# --include/--exclude patterns are already applied to the blocklist before discovery.
# This filter handles file-level ignore_files (git path skips them during ls-files)
# and the --only inclusion filter.
#
# Performance note: the old implementation called bash pattern matching for every
# file/pattern combination, which dominated large scans. Each scope now points at
# cached regex files, and awk filters the full path list in one pass.
single_pass_filter() {
  local use_ignore="$1"
  local use_only="$2"
  local file_regex_file="${3:-}"
  local dir_regex_file="${4:-}"
  local only_regex_file="${5:-}"

  if [[ "$use_ignore" != true && "$use_only" != true ]]; then
    cat
    return 0
  fi

  awk -v use_ignore="$([[ "$use_ignore" == true ]] && echo 1 || echo 0)" \
      -v use_only="$([[ "$use_only" == true ]] && echo 1 || echo 0)" \
      -v file_regex_file="$file_regex_file" \
      -v dir_regex_file="$dir_regex_file" \
      -v only_regex_file="$only_regex_file" '
  function load_regexes(path, target,    line) {
    if (path == "") return
    while ((getline line < path) > 0) {
      if (line == "") continue
      target[++target[0]] = line
    }
    close(path)
  }

  BEGIN {
    file_re[0] = dir_re[0] = only_re[0] = 0
    if (use_ignore) {
      load_regexes(file_regex_file, file_re)
      load_regexes(dir_regex_file, dir_re)
    }
    if (use_only) {
      load_regexes(only_regex_file, only_re)
    }
  }

  {
    path = $0
    filename = path
    sub(/^.*\//, "", filename)

    # Preserve historical semantics: test file globs against both basename and
    # full path, and treat directory rules as matching any path component.
    if (use_ignore) {
      for (i = 1; i <= file_re[0]; i++) {
        if (filename ~ file_re[i] || path ~ file_re[i]) next
      }
      for (i = 1; i <= dir_re[0]; i++) {
        if (path ~ dir_re[i]) next
      }
    }

    if (use_only) {
      matched = 0
      for (i = 1; i <= only_re[0]; i++) {
        if (filename ~ only_re[i] || path ~ only_re[i]) {
          matched = 1
          break
        }
      }
      if (!matched) next
    }

    print path
  }'
}

evaluate_scope() {
  local idx="$1"
  local targets_csv="${SCOPE_TARGETS[$idx]}"
  local is_changed="${SCOPE_CHANGED[$idx]}"
  local is_no_ignore="${SCOPE_NO_IGNORE[$idx]}"
  local only_csv="${SCOPE_ONLY[$idx]}"
  local skip_csv="${SCOPE_SKIP[$idx]}"
  local force_csv="${SCOPE_FORCE[$idx]}"
  local contains_pattern="${SCOPE_CONTAINS[$idx]}"
  local snippet="${SCOPE_SNIPPET[$idx]}"
  local is_staged="${SCOPE_STAGED[$idx]}"
  local is_unstaged="${SCOPE_UNSTAGED[$idx]}"
  local is_untracked="${SCOPE_UNTRACKED[$idx]}"

  local targets=()
  if [[ -n "$targets_csv" ]]; then
    IFS=',' read -ra targets <<< "$targets_csv"
  else
    targets=( "." )
  fi

  # ── Save original blocklist, modify for this scope ──
  local saved_ignore_dirs=( ${ignore_dirs[@]+"${ignore_dirs[@]}"} )
  local saved_ignore_files=( ${ignore_files[@]+"${ignore_files[@]}"} )

  # Step 1: --include patterns remove rules from blocklist
  if [[ "$is_no_ignore" == true ]]; then
    ignore_dirs=(); ignore_files=()
    warn "  ${C_WARN}⚠ --include \"*\" active: all rules disabled, full scan (slower)${RESET}\n"
  elif [[ -n "$force_csv" ]]; then
    apply_force_include "$force_csv"
  fi

  # Step 2: --exclude patterns add rules to blocklist
  if [[ -n "$skip_csv" ]]; then
    apply_skip_patterns "$skip_csv"
  fi

  # Build or reuse the precompiled matcher set for this scope after all
  # temporary blocklist mutations have been applied.
  prepare_scope_filter_cache "$idx" "$is_no_ignore" "$only_csv"
  local filter_use_ignore="${SCOPE_FILTER_USE_IGNORE[$idx]}"
  local filter_use_only="${SCOPE_FILTER_USE_ONLY[$idx]}"
  local filter_file_regex="${SCOPE_FILTER_FILE_REGEX[$idx]}"
  local filter_dir_regex="${SCOPE_FILTER_DIR_REGEX[$idx]}"
  local filter_only_regex="${SCOPE_FILTER_ONLY_REGEX[$idx]}"

  # ── Resolve targets (paths are pure discovery starting points) ──
  local discovered_file
  discovered_file=$(mktmp)

  local t resolved
  for t in "${targets[@]}"; do
    if contains_parent_traversal "$t"; then
      printf "%s\n" "${C_ERR}Error: Cannot traverse above working directory: '$t'${RESET}" >&2
      printf "  catclip only operates within the current directory tree.\n" >&2
      printf "  Use a relative path from your project root instead.\n" >&2
      printf "  Example: ${C_OK}catclip config/${RESET}\n" >&2
      exit 2
    fi
    if [[ "$t" == /* ]]; then
      printf "%s\n" "${C_ERR}Error: Absolute paths not allowed: '$t'${RESET}" >&2
      printf "  Use a relative path from your project root instead.\n" >&2
      exit 2
    fi

    if [[ -f "$t" ]]; then
      local clean="${t#./}"
      # Paths are discovery targets — always filtered by rules
      if [[ "$is_no_ignore" != true ]] && is_ignored "$clean"; then
        local rule=""
        rule=$(find_matching_rule "$clean") || true
        printf "\n%s\n" "${C_ERR}Error: '${clean}' is ignored by rule '${rule}' in .hiss${RESET}" >&2
        printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"%s\"${RESET}\n" "$rule" >&2
        printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
        printf "  ${DIM}To remove permanently:${RESET}   ${C_OK}catclip --hiss${RESET} ${DIM}(delete the rule)${RESET}\n" >&2
      else
        [[ -r "$t" ]] && is_text_file "$t" && echo "$clean" >> "$discovered_file"
      fi
    elif [[ -d "$t" ]]; then
      # Check if directory is blocked (skip for ".")
      if [[ "$t" != "." && "$is_no_ignore" != true ]] && is_dir_blocked "$t"; then
        local dirname="${t%/}"; dirname="${dirname##*/}"
        printf "\n%s\n" "${C_ERR}Error: '${t}' is ignored by .hiss${RESET}" >&2
        printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"${dirname}/\"${RESET}\n" >&2
        printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
        printf "  ${DIM}To remove permanently:${RESET}   ${C_OK}catclip --hiss${RESET} ${DIM}(delete the rule)${RESET}\n" >&2
      else
        discover_files "$t" "$is_no_ignore" "$discovered_file" "$only_csv"
      fi
    elif [[ "$t" != */* ]]; then
      # Fuzzy search for directory
      local fuzzy_rc=0
      resolved=$(fuzzy_search_dir "$t" "." "$is_no_ignore") || fuzzy_rc=$?

      if (( fuzzy_rc == 0 )); then
        discover_files "$resolved" "$is_no_ignore" "$discovered_file" "$only_csv"
      elif (( fuzzy_rc == 2 )); then
        HAD_FUZZY_FAIL=true  # Had matches but user didn't select
      elif (( fuzzy_rc == 3 )); then
        HAD_FUZZY_FAIL=true
        printf "%s\n" "${C_ERR}Error: Multiple directories match '$t'.${RESET}" >&2
        printf "  Use a more specific path segment to disambiguate.\n" >&2
      else
        # No matches at all — smart error
        local known_file=false
        local base_class
        base_class=$(_classify_basename "$t")
        [[ "$base_class" == "text" ]] && known_file=true

        if [[ "$t" == *.* || "$known_file" == true ]]; then
          # Has extension or known basename — definitely a file
          warn "${C_WARN}Warning: '%s' not found at project root.${RESET}\n" "$t"
          warn "\n  ${DIM}To find it in subdirectories:${RESET}\n"
          warn "    ${C_OK}catclip . --only \"%s\"${RESET}         ${DIM}# all matches${RESET}\n" "$t"
          warn "    ${C_OK}catclip src --only \"%s\"${RESET}       ${DIM}# within src/${RESET}\n" "$t"
        else
          # Ambiguous — could be file or directory
          warn "${C_WARN}Warning: No file or directory '%s' found (scope %d).${RESET}\n" "$t" $((idx+1))
          warn "\n  ${DIM}If it's a file in a subdirectory:${RESET}\n"
          warn "    ${C_OK}catclip . --only \"%s\"${RESET}\n" "$t"
          warn "\n  ${DIM}If it's inside an ignored directory:${RESET}\n"
          warn "    ${C_OK}catclip . --include \"dir/\"${RESET}\n"
        fi
      fi
    else
      local filename="${t##*/}" dir_path="${t%/*}"
      if resolved=$(resolve_chained_path "$dir_path" "$is_no_ignore"); then
        local full="$resolved/$filename"
        if [[ -f "$full" && -r "$full" ]]; then
          local clean="${full#./}"
          if [[ "$is_no_ignore" != true ]] && is_ignored "$clean"; then
            local rule=""
            rule=$(find_matching_rule "$clean") || true
            printf "\n%s\n" "${C_ERR}Error: '${clean}' is ignored by rule '${rule}' in .hiss${RESET}" >&2
            printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"%s\"${RESET}\n" "$rule" >&2
            printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
          else
            is_text_file "$full" && echo "$clean" >> "$discovered_file"
          fi
        elif [[ -d "$full" ]]; then
          if [[ "$is_no_ignore" != true ]] && is_dir_blocked "$full"; then
            local dirname="${full%/}"; dirname="${dirname##*/}"
            printf "\n%s\n" "${C_ERR}Error: '${full#./}' is ignored by .hiss${RESET}" >&2
            printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"${dirname}/\"${RESET}\n" >&2
            printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
            printf "  ${DIM}To remove permanently:${RESET}   ${C_OK}catclip --hiss${RESET} ${DIM}(delete the rule)${RESET}\n" >&2
          else
            discover_files "$full" "$is_no_ignore" "$discovered_file" "$only_csv"
          fi
        else
          warn "${C_WARN}Warning: Target '%s' not found (scope %d).${RESET}\n" "$t" $((idx+1))
        fi
      else
        warn "${C_WARN}Warning: Target '%s' not found (scope %d).${RESET}\n" "$t" $((idx+1))
      fi
    fi
  done

  # ── --changed / --staged / --unstaged / --untracked filter ──
  if [[ "$is_changed" == true ]]; then
    if [[ "$IS_GIT" == true ]]; then
      local changed_file
      changed_file=$(mktmp)

      local has_head=false
      git rev-parse --verify HEAD > /dev/null 2>&1 && has_head=true

      # Determine which categories to include.
      # If sub-flags are set, use only those; otherwise include all three.
      local want_staged=false want_unstaged=false want_untracked=false
      if [[ "$is_staged" == true || "$is_unstaged" == true || "$is_untracked" == true ]]; then
        [[ "$is_staged"    == true ]] && want_staged=true
        [[ "$is_unstaged"  == true ]] && want_unstaged=true
        [[ "$is_untracked" == true ]] && want_untracked=true
      else
        # --changed with no sub-flags → all three (original behaviour)
        want_staged=true; want_unstaged=true; want_untracked=true
      fi

      { [[ "$want_staged"    == true ]] && git diff --name-only --cached 2>/dev/null
        [[ "$want_unstaged"  == true ]] && git diff --name-only       2>/dev/null
        [[ "$want_untracked" == true ]] && git ls-files --others --exclude-standard 2>/dev/null
        # When using HEAD-based capture (all three) also include staged vs HEAD
        if [[ "$want_staged" == true && "$want_unstaged" == true && "$want_untracked" == true && "$has_head" == true ]]; then
          git diff --name-only HEAD 2>/dev/null
        fi
      } | sort -u > "$changed_file"

      local filtered
      filtered=$(mktmp)
      comm -12 <(sort -u "$discovered_file") "$changed_file" > "$filtered"
      cat "$filtered" > "$discovered_file"
    else
      warn "${C_WARN}Warning: --changed/--staged/--unstaged/--untracked require a git repo (scope %d).${RESET}\n" $((idx+1))
      warn "  ${DIM}This directory is not inside a git repository.${RESET}\n"
    fi
  fi

  # ── Recover gitignored files matching --include patterns ──
  # --include should bypass both .hiss (handled by apply_force_include above)
  # and .gitignore. Ask git what it's hiding, filter by the force patterns,
  # and collect into force_kept_file to merge after batch_git_filter.
  local force_kept_file=""
  if [[ -n "$force_csv" && "$IS_GIT" == true && "$is_no_ignore" != true ]]; then
    force_kept_file=$(mktmp)
    local force_raw force_classified
    force_raw=$(mktmp)
    force_classified=$(mktmp)

    local _inc_pats=()
    IFS=',' read -ra _inc_pats <<< "$force_csv"
    local _fp
    for _fp in "${_inc_pats[@]}"; do
      if [[ "$_fp" == */ ]]; then
        # Directory pattern: ask git for ignored files under that dir
        git ls-files --others --ignored --exclude-standard -- "${_fp%/}/" 2>/dev/null >> "$force_raw" || true
      else
        # File pattern: use as pathspec directly
        git ls-files --others --ignored --exclude-standard -- "$_fp" 2>/dev/null >> "$force_raw" || true
      fi
    done

    if [[ -s "$force_raw" ]]; then
      # Scope to current targets (remove files outside the target dirs).
      local _ft
      for _ft in "${targets[@]}"; do
        local _tclean="${_ft#./}"
        [[ "$_tclean" == "." ]] && { cat "$force_raw"; break; }
        awk -v d="$_tclean" 'index($0, d "/") == 1 || $0 == d' "$force_raw"
      done | sort -u > "${force_raw}.scoped"
      mv "${force_raw}.scoped" "$force_raw"

      batch_classify_files "$force_raw" "$force_classified"
      if [[ -s "$force_classified" ]]; then
        sort -u "$force_classified" > "$force_kept_file"
        vlog "Recovered $(awk 'END{print NR}' "$force_kept_file") gitignored files via --include"
      fi
    fi
  fi

  # ── Filter pipeline ──
  sort -u "$discovered_file" \
    | if [[ "$is_no_ignore" != true && "$IS_GIT" == true && "$HAS_GITIGNORE" == true ]]; then
        batch_git_filter
      else
        cat
      fi \
    | if [[ -n "$force_kept_file" && -s "$force_kept_file" ]]; then
        cat - "$force_kept_file" | sort -u
      else
        cat
      fi \
    | single_pass_filter "$filter_use_ignore" "$filter_use_only" \
        "$filter_file_regex" "$filter_dir_regex" "$filter_only_regex" \
    | if [[ -n "$contains_pattern" ]]; then
        local contains_in contains_out
        contains_in=$(mktmp)
        contains_out=$(mktmp)
        cat > "$contains_in"
        if [[ -s "$contains_in" ]]; then
          tr '\n' '\0' < "$contains_in" \
            | xargs -0 grep -lE -- "$contains_pattern" 2>/dev/null \
            > "$contains_out" || true
          cat "$contains_out"
        fi
      else
        cat
      fi

  # ── Restore original blocklist ──
  ignore_dirs=( ${saved_ignore_dirs[@]+"${saved_ignore_dirs[@]}"} )
  ignore_files=( ${saved_ignore_files[@]+"${saved_ignore_files[@]}"} )
}

get_scope_label() {
  local idx="$1"
  local t="${SCOPE_TARGETS[$idx]}"
  [[ -z "$t" ]] && t="."
  local desc="${C_DIR}${t//,/, }${RESET}"
  local flags=""

  [[ "${SCOPE_CHANGED[$idx]}" == true ]] && flags="${flags} ${C_GIT}--changed${RESET}"
  local o="${SCOPE_ONLY[$idx]}"
  [[ -n "$o" ]] && flags="${flags} ${C_OK}--only ${o//,/, }${RESET}"
  local sk="${SCOPE_SKIP[$idx]}"
  [[ -n "$sk" ]] && flags="${flags} ${C_WARN}--exclude ${sk}${RESET}"
  local fi_="${SCOPE_FORCE[$idx]}"
  [[ -n "$fi_" ]] && flags="${flags} ${C_OK}--include ${fi_}${RESET}"
  [[ "${SCOPE_NO_IGNORE[$idx]}" == true ]] && flags="${flags} ${C_ERR}--include \"*\"${RESET}"
  local ct="${SCOPE_CONTAINS[$idx]}"
  [[ -n "$ct" ]]                            && flags="${flags} ${C_OK}--contains ${ct}${RESET}"
  [[ "${SCOPE_SNIPPET[$idx]}"   == true ]] && flags="${flags} ${C_OK}--snippet${RESET}"
  [[ "${SCOPE_STAGED[$idx]}"    == true ]] && flags="${flags} ${C_GIT}--staged${RESET}"
  [[ "${SCOPE_UNSTAGED[$idx]}"  == true ]] && flags="${flags} ${C_GIT}--unstaged${RESET}"
  [[ "${SCOPE_UNTRACKED[$idx]}" == true ]] && flags="${flags} ${C_GIT}--untracked${RESET}"
  [[ "${SCOPE_DIFF[$idx]}"      == true ]] && flags="${flags} ${C_OK}--diff${RESET}"

  [[ -n "$flags" ]] && desc="$desc ${DIM}(${flags# })${RESET}"
  echo "$desc"
}

# ==============================================================================
# HISS MANAGEMENT
# ==============================================================================

# Trust boundary: $VISUAL/$EDITOR are user-controlled env vars.
# Word-splitting $editor is intentional — editors accept flags (e.g. "code --wait").
# command -v validates the binary exists; arguments are the user's responsibility.
open_hiss() {
  ensure_config
  local editor="${VISUAL:-${EDITOR:-nano}}"
  if ! command -v "${editor%% *}" &>/dev/null; then
    editor="nano"
    if ! command -v nano &>/dev/null; then
      printf "%s\n" "${C_ERR}Error: No editor found. Set \$EDITOR or install nano.${RESET}" >&2
      exit 1
    fi
  fi
  printf "%s\n" "${DIM}Opening $(short_path "$GLOBAL_HISS") in ${editor%% *}...${RESET}" >&2
  $editor "$GLOBAL_HISS"
}

stream_output_content() {
  local list_file="$1"
  local output_mode="$2"
  local diff_staged="$3"
  local diff_unstaged="$4"
  local snippet_pattern="${5:-}"

  case "$output_mode" in
    diff)
      local _df
      while IFS= read -r _df; do
        extract_diff "$_df" "$diff_staged" "$diff_unstaged"
      done < "$list_file"
      ;;
    snippet)
      local _sf
      while IFS= read -r _sf; do
        extract_snippets "$_sf" "$snippet_pattern"
      done < "$list_file"
      ;;
    *)
      awk -v warn="$C_WARN" -v rst="$RESET" -v quiet="$QUIET" '
      {
        f = "./" $0
        r = (getline line < f)
        if (r < 0) {
          if (quiet != "true") {
            printf "%sWarning: Cannot read %s. Skipping.%s\n", warn, f, rst > "/dev/stderr"
          }
          next
        }
        print "<file path=\"" $0 "\">"
        if (r > 0) {
          print line
          while ((getline line < f) > 0) print line
        }
        close(f)
        print "</file>\n"
      }' "$list_file"
      ;;
  esac
}

# ==============================================================================
# MAIN
# ==============================================================================

main() {
  IS_GIT=false
  HAS_GITIGNORE=false
  GIT_ROOT=""
  AUTO_CONFIRM=false
  PRINT_CONTENT=false
  if [[ "$HAS_GIT" == true ]]; then
    if GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null); then
      IS_GIT=true
      [[ -f "$GIT_ROOT/.gitignore" ]] && HAS_GITIGNORE=true
    fi
  fi

  ensure_config
  load_ignores



  # ── Arg parsing ──
  # [Point 9] Scope accumulator state is global, not local to main.
  # close_scope() is a nested function that mutates these — using globals
  # makes the mutation explicit and survives refactoring.
  local skip_confirm=false no_tree=false preview=false
  local any_no_ignore=false any_changed=false

  # Flush accumulated scope state into the parallel scope arrays.
  close_scope() {
    # Flush if we have targets OR any modifier was set (implicit "." target)
    local _has_modifiers=false
    if [[ "$_cur_changed" == true || "$_cur_no_ignore" == true || -n "$_cur_contains" \
       || "$_cur_snippet" == true || "$_cur_staged" == true || "$_cur_unstaged" == true \
       || "$_cur_untracked" == true || "$_cur_diff" == true ]] \
       || (( ${#_cur_only[@]} > 0 || ${#_cur_skip[@]} > 0 || ${#_cur_force[@]} > 0 )); then
      _has_modifiers=true
    fi

    if (( ${#_cur_targets[@]} > 0 )) || [[ "$_has_modifiers" == true ]]; then

      # --diff + --untracked alone is pointless (untracked files have no diff)
      if [[ "$_cur_diff" == true && "$_cur_untracked" == true \
         && "$_cur_staged" != true && "$_cur_unstaged" != true && "$_cur_changed" != true ]]; then
        printf "%s\n" "${C_ERR}Error: --untracked --diff doesn't make sense (untracked files have no diff).${RESET}" >&2
        printf "  Try: catclip --changed --diff    (includes untracked as full content)\n" >&2
        printf "  Try: catclip --staged --diff     (only staged patches)\n" >&2
        exit 2
      fi

      # --staged/--unstaged/--untracked imply --changed
      if [[ "$_cur_staged" == true || "$_cur_unstaged" == true || "$_cur_untracked" == true ]]; then
        _cur_changed=true; any_changed=true
      fi

      # --snippet requires --contains
      if [[ "$_cur_snippet" == true && -z "$_cur_contains" ]]; then
        printf "%s\n" "${C_ERR}Error: --snippet requires --contains (it extracts blocks around content matches).${RESET}" >&2
        printf "  Example: catclip src --contains 'TODO' --snippet\n" >&2
        exit 2
      fi

      # --snippet and --diff are mutually exclusive output formats
      if [[ "$_cur_snippet" == true && "$_cur_diff" == true ]]; then
        printf "%s\n" "${C_ERR}Error: --snippet and --diff cannot be combined.${RESET}" >&2
        printf "  Use --snippet to extract blocks around content matches.\n" >&2
        printf "  Use --diff to show unified git patches.\n" >&2
        exit 2
      fi

      # --diff requires a change-selection flag
      if [[ "$_cur_diff" == true && "$_cur_changed" != true ]]; then
        printf "%s\n" "${C_ERR}Error: --diff requires --changed, --staged, --unstaged, or --untracked.${RESET}" >&2
        printf "  Example: catclip src --changed --diff\n" >&2
        printf "  Example: catclip src --staged --diff\n" >&2
        exit 2
      fi

      local t_str="" o_str="" s_str="" f_str="" sep=""
      if (( ${#_cur_targets[@]} > 0 )); then
        local t; for t in "${_cur_targets[@]}"; do t_str="${t_str}${sep}${t}"; sep=","; done
      else
        t_str="."
      fi
      sep=""
      local p; for p in ${_cur_only[@]+"${_cur_only[@]}"}; do o_str="${o_str}${sep}${p}"; sep=","; done
      sep=""
      for p in ${_cur_skip[@]+"${_cur_skip[@]}"}; do s_str="${s_str}${sep}${p}"; sep=","; done
      sep=""
      for p in ${_cur_force[@]+"${_cur_force[@]}"}; do f_str="${f_str}${sep}${p}"; sep=","; done

      add_scope "$t_str" "$_cur_changed" "$_cur_no_ignore" "$o_str" "$s_str" "$f_str" \
        "$_cur_contains" "$_cur_snippet" "$_cur_staged" "$_cur_unstaged" "$_cur_untracked" "$_cur_diff"

      _cur_targets=(); _cur_changed=false; _cur_no_ignore=false
      _cur_only=(); _cur_skip=(); _cur_force=(); _cur_contains=""; _cur_snippet=false
      _cur_staged=false; _cur_unstaged=false; _cur_untracked=false; _cur_diff=false
    fi
  }

  while (( $# )); do
    case "$1" in
      -h|--help)      print_help; exit 0 ;;
      --help-all)     print_help_all; exit 0 ;;
      --version|-V)   echo "catclip $VERSION"; exit 0 ;;
      -v|--verbose)   VERBOSE=true; shift ;;
      -q|--quiet)     QUIET=true; shift ;;
      -y|--yes)       skip_confirm=true; AUTO_CONFIRM=true; shift ;;
      -p|--print)     PRINT_CONTENT=true; shift ;;
      -t|--no-tree)   no_tree=true; shift ;;
      --preview)      preview=true; shift ;;
      --hiss) open_hiss; exit 0 ;;
      --hiss-reset)
        local short_hiss
        short_hiss=$(short_path "$GLOBAL_HISS")
        printf "%s\n" "${C_WARN}This will overwrite ${BOLD}${short_hiss}${RESET}${C_WARN} with defaults.${RESET}" >&2
        if prompt_yn "Are you sure? [y/N]" "n"; then
          mkdir -p "$CONFIG_DIR"
          get_default_hiss > "$GLOBAL_HISS"
          printf "%s\n" "${C_OK}Configuration restored.${RESET}" >&2
        else
          printf "Cancelled.\n" >&2
        fi
        exit 0
        ;;
      --changed)
        _cur_changed=true; any_changed=true; shift
        ;;
      --only)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --only requires a pattern.${RESET}" >&2
          printf "  Example: catclip src --only '*.ts'\n" >&2
          exit 2
        fi
        _cur_only+=( "$1" ); shift
        ;;
      --then)
        close_scope; shift
        ;;
      --)
        shift
        while (( $# )); do
          _cur_targets+=( "$1" ); shift
        done
        break
        ;;
      --include)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --include requires a pattern.${RESET}" >&2
          printf "  Example: catclip src --include 'tests/'\n" >&2
          exit 2
        fi
        if [[ "$1" == "*" ]]; then
          _cur_no_ignore=true; any_no_ignore=true
        else
          local _inc_pats=()
          IFS=',' read -ra _inc_pats <<< "$1"
          local _ip; for _ip in "${_inc_pats[@]}"; do
            [[ -n "$_ip" ]] && _cur_force+=( "$_ip" )
          done
        fi
        shift
        ;;
      --exclude)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --exclude requires a pattern.${RESET}" >&2
          printf "  Example: catclip src --exclude '*.test.*'\n" >&2
          exit 2
        fi
        local _exc_pats=()
        IFS=',' read -ra _exc_pats <<< "$1"
        local _ep; for _ep in "${_exc_pats[@]}"; do
          [[ -n "$_ep" ]] && _cur_skip+=( "$_ep" )
        done
        shift
        ;;
      --contains=*)
        printf "%s\n" "${C_ERR}Error: --contains requires a space before the pattern.${RESET}" >&2
        printf "  Use: catclip src --contains 'pattern'\n" >&2
        printf "  Not: catclip src --contains='pattern'\n" >&2
        exit 2
        ;;
      --contains)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --contains requires a regex pattern.${RESET}" >&2
          printf "  Example: catclip src --contains 'TODO'\n" >&2
          exit 2
        fi
        if [[ "$1" == *'*'* && "$1" != *'.'* && "$1" != *'['* && "$1" != *'|'* && "$1" != *'\\'* ]]; then
          warn "${C_WARN}Warning: --contains uses regex, not globs. Did you mean '.*' instead of '*'?${RESET}\n"
          warn "  ${DIM}Example: --contains 'use.*Context' (not 'use*Context')${RESET}\n"
        fi
        _cur_contains="$1"; shift
        ;;
      --snippet)
        _cur_snippet=true; shift
        ;;
      --staged)
        _cur_staged=true; shift
        ;;
      --unstaged)
        _cur_unstaged=true; shift
        ;;
      --untracked)
        _cur_untracked=true; shift
        ;;
      --diff)
        _cur_diff=true; shift
        ;;
      --*)
        printf "%s\n" "${C_ERR}Error: Unknown option '$1'${RESET}" >&2
        printf "  Run 'catclip --help' for available options.\n" >&2
        exit 2
        ;;
      -?*)
        printf "%s\n" "${C_ERR}Error: Unknown option '$1'${RESET}" >&2
        printf "  Run 'catclip --help' for available options.\n" >&2
        exit 2
        ;;
      *)
        _cur_targets+=( "$1" ); shift
        ;;
    esac
  done
  close_scope

  local num_scopes
  num_scopes=$(scope_count)

  if (( num_scopes == 0 )); then
    add_scope "." "false" "false" "" "" "" "" "false" "false" "false" "false" "false"
    num_scopes=1
  fi

  # ── Phase 1: Discovery ──
  local t_discovery
  t_discovery=$(timer_start)
  local list_file
  list_file=$(mktmp)
  local mode_file
  mode_file=$(mktmp)
  local total_files=0

  # Only show scope headers when there are multiple scopes.
  if (( num_scopes > 1 )); then
    info "${BOLD}Scanning...${RESET}\n"
  fi

  local i
  for (( i = 0; i < num_scopes; i++ )); do
    if (( num_scopes > 1 )); then
      local label
      label=$(get_scope_label "$i")
      info "${BOLD}Scope %d:${RESET} %s\n" $((i+1)) "$label"
    fi

    local scope_result
    scope_result=$(mktmp)
    evaluate_scope "$i" > "$scope_result"

    local n
    n=$(count_lines "$scope_result")
    if (( num_scopes > 1 )); then
      info "  ${C_LABEL}%d %s${RESET}\n\n" "$n" "$(plural "$n")"
    fi
    cat "$scope_result" >> "$list_file"

    # Build per-file output mode annotations for tree tags.
    local _mode_tag=""
    if [[ "${SCOPE_DIFF[$i]}" == true ]]; then
      _mode_tag="diff only"
    elif [[ "${SCOPE_SNIPPET[$i]}" == true ]]; then
      _mode_tag="snippet only"
    fi
    if [[ -n "$_mode_tag" ]]; then
      while IFS= read -r _mf; do
        printf '%s\t%s\n' "$_mf" "$_mode_tag"
      done < "$scope_result" >> "$mode_file"
    fi

    total_files=$((total_files + n))
  done

  sort -u "$list_file" -o "$list_file"
  local final_count
  final_count=$(count_lines "$list_file")
  # Dedup message is verbose-only — not useful at default verbosity.
  if (( final_count != total_files && num_scopes > 1 )); then
    vlog "Deduplicated: $final_count unique (from $total_files across scopes)"
  fi
  total_files="$final_count"
  timer_end "$t_discovery" "Discovery"

  if (( total_files == 0 )); then
    # Context-aware empty message: distinguish --changed from general empty.
    if [[ "$HAD_FUZZY_FAIL" == true ]]; then
      # User saw matches but didn't select — no diagnostic needed
      :
    elif [[ "$any_changed" == true ]]; then
      # Build a flag label from what the user actually typed.
      local _change_flags="" _has_staged=false _has_unstaged=false _has_untracked=false
      local _ci
      for (( _ci = 0; _ci < num_scopes; _ci++ )); do
        [[ "${SCOPE_STAGED[$_ci]}"    == true ]] && { _change_flags="${_change_flags:+$_change_flags/}--staged";    _has_staged=true; }
        [[ "${SCOPE_UNSTAGED[$_ci]}"  == true ]] && { _change_flags="${_change_flags:+$_change_flags/}--unstaged";  _has_unstaged=true; }
        [[ "${SCOPE_UNTRACKED[$_ci]}" == true ]] && { _change_flags="${_change_flags:+$_change_flags/}--untracked"; _has_untracked=true; }
      done
      [[ -z "$_change_flags" ]] && _change_flags="--changed"
      printf "%s\n" "${C_WARN}No ${_change_flags} files found.${RESET}" >&2
      # Flag-specific hints.
      if [[ "$_has_staged" == true && "$_has_unstaged" != true && "$_has_untracked" != true ]]; then
        printf "  ${DIM}No files are staged for commit. Use 'git add' to stage changes.${RESET}\n" >&2
      elif [[ "$_has_unstaged" == true && "$_has_staged" != true && "$_has_untracked" != true ]]; then
        printf "  ${DIM}No tracked files have uncommitted modifications.${RESET}\n" >&2
      elif [[ "$_has_untracked" == true && "$_has_staged" != true && "$_has_unstaged" != true ]]; then
        printf "  ${DIM}No new untracked files in the target directories.${RESET}\n" >&2
      else
        printf "  ${DIM}Your working tree may be clean, or the target has no modifications.${RESET}\n" >&2
      fi
      printf "  ${DIM}Run without ${_change_flags} to copy all files.${RESET}\n" >&2
    else
      printf "%s\n" "${C_WARN}No text files found matching your criteria.${RESET}" >&2
      printf "\n  ${DIM}Possible causes:${RESET}\n" >&2
      printf "  ${DIM}  1. Directory is empty or contains only binary files${RESET}\n" >&2
      printf "  ${DIM}  2. All files matched by ignore rules${RESET}\n" >&2
      printf "  ${DIM}  3. Typo in target name${RESET}\n" >&2
      printf "\n  ${DIM}Try: catclip --hiss                   # view/edit ignore rules${RESET}\n" >&2
      printf "  ${DIM}     catclip . --include \"*\"          # disable all ignore rules${RESET}\n" >&2
    fi
    exit 1
  fi

  # ── Phase 2: Size & tokens ──
  local t_size
  t_size=$(timer_start)
  local total_bytes=0
  # For --preview, we need per-file sizes anyway, so capture them here
  # and derive the total — avoids running stat twice.
  local sizes_file=""
  if [[ "$no_tree" == false ]]; then
    sizes_file=$(mktmp)
    if [[ "$PLATFORM" == "macos" ]]; then
      paste "$list_file" <(tr '\n' '\0' < "$list_file" | xargs -0 stat -f %z 2>/dev/null) > "$sizes_file"
    else
      paste "$list_file" <(tr '\n' '\0' < "$list_file" | xargs -0 stat -c %s 2>/dev/null) > "$sizes_file"
    fi
    total_bytes=$(awk -F'\t' '{s+=$2} END {print s+0}' "$sizes_file")
  else
    if [[ "$PLATFORM" == "macos" ]]; then
      total_bytes=$(tr '\n' '\0' < "$list_file" \
        | xargs -0 stat -f %z 2>/dev/null \
        | awk '{s+=$1} END {print s+0}')
    else
      total_bytes=$(tr '\n' '\0' < "$list_file" \
        | xargs -0 stat -c %s 2>/dev/null \
        | awk '{s+=$1} END {print s+0}')
    fi
  fi
  if [[ ! "$total_bytes" =~ ^[0-9]+$ ]]; then
    total_bytes=0
    local s
    while IFS= read -r f; do
      s=$(get_file_size "./$f")
      [[ "$s" =~ ^[0-9]+$ ]] || s=0
      total_bytes=$((total_bytes + s))
    done < "$list_file"
  fi

  local size_tokens human_size est_tokens
  size_tokens=$(format_size_and_tokens "$total_bytes" "$total_files")
  human_size="${size_tokens% *}"
  est_tokens="${size_tokens##* }"
  timer_end "$t_size" "Size calculation"

  local TOKEN_WARN=100000
  local short_config
  short_config=$(short_path "$GLOBAL_HISS")

  # ── Phase 3: Preview ──
  if [[ "$any_no_ignore" == true ]]; then
    info "  ${C_WARN}Safety filters disabled (+\"*\")${RESET}\n"
  elif [[ "$IS_GIT" == true && "$HAS_GITIGNORE" == true ]]; then
    info "  ${C_GIT}Filtered by .gitignore + %s${RESET}\n" "$short_config"
  elif [[ "$IS_GIT" == true ]]; then
    info "  ${C_WARN}Git repo, but no .gitignore; only %s applies.${RESET}\n" "$short_config"
  elif [[ "$HAS_GIT" == false ]]; then
    info "  ${C_WARN}git not installed; only %s applies.${RESET}\n" "$short_config"
  else
    info "  ${C_WARN}Not a git repo; only %s applies.${RESET}\n" "$short_config"
  fi

  local git_status_file=""
  if [[ "$no_tree" == false && "$IS_GIT" == true ]]; then
    git_status_file=$(mktmp)
    # Generate git status map (path\tstatus_letter) — single awk pass.
    git status --porcelain 2>/dev/null | awk '{
      xy = substr($0, 1, 2)
      path = substr($0, 4)
      # Rename/copy: porcelain v1 uses " -> " separator.
      # Assumes no filenames contain literal " -> " (safe for practical use).
      n = split(path, rp, / -> /)
      if (n > 1) path = rp[n]
      sub(/\/$/, "", path)
      if (xy == "??")                                   print path "\t?"
      else if (substr(xy,1,1) == "A")                   print path "\tA"
      else if (substr(xy,1,1) != " " && substr(xy,1,1) != "?") print path "\tS"
      else if (substr(xy,2,1) == "M" || substr(xy,2,1) == "D") print path "\tM"
    }' > "$git_status_file"
  fi

  # Detect landmark directories for path annotations in the tree.
  local landmarks_file=""
  if [[ "$no_tree" == false ]]; then
    landmarks_file=$(mktmp)
    detect_landmarks "$list_file" > "$landmarks_file"
  fi

  local file_word
  file_word=$(plural "$total_files")
  if [[ "$preview" == true ]]; then
    # --preview: enriched tree (sizes already collected in Phase 2) + git status.
    if [[ "$no_tree" == false ]]; then
      print_tree "$list_file" "$sizes_file" "$git_status_file" "$mode_file" "$landmarks_file"
    fi
    printf "\n  ${C_LABEL}%-8s${RESET} ${C_VALUE}%d %s${RESET}\n" "Count:" "$total_files" "$file_word"
    printf "  ${C_LABEL}%-8s${RESET} ${C_VALUE}%s${RESET}\n" "Size:" "$human_size"
    printf "  ${C_LABEL}%-8s${RESET} ${C_VALUE}~%d${RESET}\n" "Tokens:" "$est_tokens"
    exit 0
  else
    if [[ "$no_tree" == false && "$QUIET" != true ]]; then
      print_tree "$list_file" "$sizes_file" "$git_status_file" "$mode_file" "$landmarks_file" >&2
    fi
    info "\n  ${C_LABEL}%-8s${RESET} ${C_VALUE}%d %s${RESET}\n" "Count:" "$total_files" "$file_word"
    info "  ${C_LABEL}%-8s${RESET} ${C_VALUE}%s${RESET}\n" "Size:" "$human_size"
    info "  ${C_LABEL}%-8s${RESET} ${C_VALUE}~%d${RESET}\n" "Tokens:" "$est_tokens"
  fi

  if (( est_tokens > TOKEN_WARN )); then
    info "  ${C_WARN}~%d tokens may exceed some LLM context windows.${RESET}\n" "$est_tokens"
  fi

  # ── Confirmation ──
  if [[ "$skip_confirm" == false && "$QUIET" != true ]] && (( est_tokens > TOKEN_WARN )); then
    if ! prompt_yn "${C_PROMPT}Proceed? [y/N]${RESET}" "n"; then
      printf "${C_WARN}Aborted.${RESET}\n" >&2
      exit 0
    fi
  fi

  # ── Phase 4: Build output ──
  # Determine output mode: diff > snippet > normal (first matching scope wins).
  local output_mode="normal"
  local _any_diff=false _diff_staged=false _diff_unstaged=false
  local _any_snippet=false _snippet_pattern=""
  local _si
  for (( _si = 0; _si < num_scopes; _si++ )); do
    if [[ "${SCOPE_DIFF[_si]}" == true && "$_any_diff" != true ]]; then
      _any_diff=true
      output_mode="diff"
      [[ "${SCOPE_STAGED[_si]}"   == true ]] && _diff_staged=true
      [[ "${SCOPE_UNSTAGED[_si]}" == true ]] && _diff_unstaged=true
    fi
    if [[ "${SCOPE_SNIPPET[_si]}" == true && "$_any_snippet" != true ]]; then
      _any_snippet=true
      [[ "$_any_diff" != true ]] && output_mode="snippet"
      _snippet_pattern="${SCOPE_CONTAINS[_si]}"
    fi
  done

  # Extract first and last file for the success message.
  local first_file last_file
  first_file=$(head -1 "$list_file")
  last_file=$(tail -1 "$list_file")

  # Detect clipboard before generation so we can fail fast and stream directly
  # into the sink instead of materializing a temp output file first.
  if [[ "$PRINT_CONTENT" != true ]]; then
    if ! detect_clipboard_cmd; then
      printf "${C_ERR}Error: No clipboard tool found.${RESET}\n" >&2
      print_clipboard_install_hint
      printf "\n${DIM}Or use --print to output to stdout:${RESET}\n" >&2
      printf "  catclip --print src > output.txt\n" >&2
      exit 1
    fi
  fi

  local t_build
  t_build=$(timer_start)
  local stream_ok=true
  if [[ "$PRINT_CONTENT" == true ]]; then
    if ! stream_output_content "$list_file" "$output_mode" \
        "$_diff_staged" "$_diff_unstaged" "$_snippet_pattern"; then
      stream_ok=false
    fi
  else
    if ! stream_output_content "$list_file" "$output_mode" \
        "$_diff_staged" "$_diff_unstaged" "$_snippet_pattern" \
        | "${CLIPBOARD_CMD[@]}" 2>/dev/null; then
      stream_ok=false
    fi
  fi
  timer_end "$t_build" "Build output"

  # ── Phase 5: Output ──
  local t_clip
  t_clip=$(timer_start)

  if [[ "$stream_ok" != true ]]; then
    if [[ "$PRINT_CONTENT" == true ]]; then
      printf "\n${C_ERR}Output failed.${RESET}\n" >&2
    else
      printf "\n${C_ERR}Clipboard copy failed.${RESET}\n" >&2
      print_clipboard_install_hint
      printf "\n${DIM}Use --print to output to stdout:${RESET}\n" >&2
      printf "  catclip --print src > output.txt\n" >&2
    fi
    exit 1
  fi

  if [[ "$PRINT_CONTENT" != true ]]; then
    if (( total_files == 1 )); then
      info "\n${C_OK}Copied${RESET} ${BOLD}%s${RESET} ${C_OK}to clipboard${RESET}\n" "$first_file"
    elif [[ "$first_file" == "$last_file" ]]; then
      info "\n${C_OK}Copied${RESET} ${BOLD}%d %s${RESET} ${C_OK}to clipboard${RESET}\n" "$total_files" "$file_word"
    else
      info "\n${C_OK}Copied${RESET} ${BOLD}%d %s${RESET} ${C_OK}to clipboard${RESET} ${DIM}(%s ... %s)${RESET}\n" \
        "$total_files" "$file_word" "$first_file" "$last_file"
    fi
  fi
  timer_end "$t_clip" "Output"

  vlog "Total: ${SECONDS}s"
}

# [Point 9] Scope accumulator as globals — close_scope() mutates these.
# Declared here so they're visible to both main() and close_scope().
_cur_targets=()
_cur_changed=false
_cur_no_ignore=false
_cur_only=()
_cur_skip=()
_cur_force=()
_cur_contains=""
_cur_snippet=false
_cur_staged=false
_cur_unstaged=false
_cur_untracked=false
_cur_diff=false

main "$@"
