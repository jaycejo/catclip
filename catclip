# ==============================================================================
# CLIPBOARD
#
# Stored as an array — no eval. Array dispatch is injection-proof.
# ==============================================================================

CLIPBOARD_CMD=()

detect_clipboard_cmd() {
  case "$PLATFORM" in
    macos)
      command -v pbcopy &>/dev/null && { CLIPBOARD_CMD=(pbcopy); return 0; } ;;
    wsl)
      command -v clip.exe &>/dev/null && { CLIPBOARD_CMD=(clip.exe); return 0; } ;;
  esac

  local is_wayland=false
  [[ "${XDG_SESSION_TYPE:-}" == "wayland" || -n "${WAYLAND_DISPLAY:-}" ]] && is_wayland=true

  if [[ "$is_wayland" == true ]]; then
    command -v wl-copy &>/dev/null && { CLIPBOARD_CMD=(wl-copy); return 0; }
    command -v xclip &>/dev/null  && { CLIPBOARD_CMD=(xclip -selection clipboard); return 0; }
    command -v xsel &>/dev/null   && { CLIPBOARD_CMD=(xsel --clipboard --input); return 0; }
  else
    command -v xclip &>/dev/null && { CLIPBOARD_CMD=(xclip -selection clipboard); return 0; }
    command -v xsel &>/dev/null  && { CLIPBOARD_CMD=(xsel --clipboard --input); return 0; }
  fi
  return 1
}

print_clipboard_install_hint() {
  case "$PLATFORM" in
    macos) printf "  Ensure pbcopy is in PATH (ships with macOS).\n" >&2 ;;
    wsl)   printf "  Ensure clip.exe is available (ships with WSL).\n" >&2 ;;
    linux)
      if [[ "${XDG_SESSION_TYPE:-}" == "wayland" || -n "${WAYLAND_DISPLAY:-}" ]]; then
        printf "  Wayland detected. Install wl-clipboard:\n" >&2
        printf "    sudo apt install wl-clipboard    ${DIM}# Debian/Ubuntu${RESET}\n" >&2
        printf "    sudo pacman -S wl-clipboard      ${DIM}# Arch${RESET}\n" >&2
      else
        printf "  X11 detected. Install xclip:\n" >&2
        printf "    sudo apt install xclip           ${DIM}# Debian/Ubuntu${RESET}\n" >&2
        printf "    sudo pacman -S xclip             ${DIM}# Arch${RESET}\n" >&2
      fi ;;
  esac
}

# ==============================================================================
# SCOPE STORAGE & EVALUATION
#
# [Point 1] Parallel arrays indexed by scope number instead of string packing.
# --include removes rules, --exclude adds rules. Both modify the in-memory blocklist before discovery.
# ==============================================================================

# Parallel arrays — one entry per scope.
SCOPE_TARGETS=()
SCOPE_CHANGED=()
SCOPE_NO_IGNORE=()
SCOPE_ONLY=()
SCOPE_SKIP=()
SCOPE_FORCE=()
SCOPE_CONTAINS=()
HAD_FUZZY_FAIL=false

add_scope() {
  SCOPE_TARGETS+=( "$1" )
  SCOPE_CHANGED+=( "$2" )
  SCOPE_NO_IGNORE+=( "$3" )
  SCOPE_ONLY+=( "$4" )
  SCOPE_SKIP+=( "$5" )
  SCOPE_FORCE+=( "$6" )
  SCOPE_CONTAINS+=( "$7" )
}

  # Prefer inlining ${#SCOPE_TARGETS[@]} at call sites to avoid
  # subshell forks. This function exists only for the few places
  # where a command substitution is unavoidable (e.g. local assignment).
scope_count() {
  echo "${#SCOPE_TARGETS[@]}"
}

# Single-pass filter: is_ignored + --only.
# --include/--exclude patterns are already applied to the blocklist before discovery.
# This filter handles file-level ignore_files (git path skips them during ls-files)
# and the --only inclusion filter.
single_pass_filter() {
  local is_no_ignore="$1"
  local only_csv="$2"

  # Parse --only patterns once.
  local only_pats=()
  if [[ -n "$only_csv" ]]; then
    IFS=',' read -ra only_pats <<< "$only_csv"
  fi

  local f p match
  while IFS= read -r f; do
    # ── Safety filter ──
    if [[ "$is_no_ignore" != true ]]; then
      is_ignored "$f" && continue
    fi

    # ── --only filter (OR across patterns) ──
    if (( ${#only_pats[@]} > 0 )); then
      match=false
      for p in "${only_pats[@]}"; do
        matches_pattern "$f" "$p" && { match=true; break; }
      done
      [[ "$match" != true ]] && continue
    fi

    echo "$f"
  done
}

evaluate_scope() {
  local idx="$1"
  local targets_csv="${SCOPE_TARGETS[$idx]}"
  local is_changed="${SCOPE_CHANGED[$idx]}"
  local is_no_ignore="${SCOPE_NO_IGNORE[$idx]}"
  local only_csv="${SCOPE_ONLY[$idx]}"
  local skip_csv="${SCOPE_SKIP[$idx]}"
  local force_csv="${SCOPE_FORCE[$idx]}"
  local contains_pattern="${SCOPE_CONTAINS[$idx]}"

  local targets=()
  if [[ -n "$targets_csv" ]]; then
    IFS=',' read -ra targets <<< "$targets_csv"
  else
    targets=( "." )
  fi

  # ── Save original blocklist, modify for this scope ──
  local saved_ignore_dirs=( ${ignore_dirs[@]+"${ignore_dirs[@]}"} )
  local saved_ignore_files=( ${ignore_files[@]+"${ignore_files[@]}"} )

  # Step 1: --include patterns remove rules from blocklist
  if [[ "$is_no_ignore" == true ]]; then
    ignore_dirs=(); ignore_files=()
    printf "  ${C_WARN}⚠ --include \"*\" active: all rules disabled, full scan (slower)${RESET}\n" >&2
  elif [[ -n "$force_csv" ]]; then
    apply_force_include "$force_csv"
  fi

  # Step 2: --exclude patterns add rules to blocklist
  if [[ -n "$skip_csv" ]]; then
    apply_skip_patterns "$skip_csv"
  fi

  # Rebuild patterns with modified blocklist (--include/--exclude already applied)
  build_ignore_patterns

  # ── Resolve targets (paths are pure discovery starting points) ──
  local discovered_file
  discovered_file=$(mktmp)

  local t
  for t in "${targets[@]}"; do
    if contains_parent_traversal "$t"; then
      printf "%s\n" "${C_ERR}Error: Cannot traverse above working directory: '$t'${RESET}" >&2
      printf "  catclip only operates within the current directory tree.\n" >&2
      printf "  Use a relative path from your project root instead.\n" >&2
      printf "  Example: ${C_OK}catclip config/${RESET}\n" >&2
      exit 2
    fi
    if [[ "$t" == /* ]]; then
      printf "%s\n" "${C_ERR}Error: Absolute paths not allowed: '$t'${RESET}" >&2
      printf "  Use a relative path from your project root instead.\n" >&2
      exit 2
    fi

    if [[ -f "$t" ]]; then
      local clean="${t#./}"
      # Paths are discovery targets — always filtered by rules
      if [[ "$is_no_ignore" != true ]] && is_ignored "$clean"; then
        local rule=""
        rule=$(find_matching_rule "$clean") || true
        printf "\n%s\n" "${C_ERR}Error: '${clean}' is ignored by rule '${rule}' in .hiss${RESET}" >&2
        printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"%s\"${RESET}\n" "$rule" >&2
        printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
        printf "  ${DIM}To remove permanently:${RESET}   ${C_OK}catclip --hiss${RESET} ${DIM}(delete the rule)${RESET}\n" >&2
      else
        [[ -r "$t" ]] && is_text_file "$t" && echo "$clean" >> "$discovered_file"
      fi
    elif [[ -d "$t" ]]; then
      # Check if directory is blocked (skip for ".")
      if [[ "$t" != "." && "$is_no_ignore" != true ]] && is_dir_blocked "$t"; then
        local dirname="${t%/}"; dirname="${dirname##*/}"
        printf "\n%s\n" "${C_ERR}Error: '${t}' is ignored by .hiss${RESET}" >&2
        printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"${dirname}/\"${RESET}\n" >&2
        printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
        printf "  ${DIM}To remove permanently:${RESET}   ${C_OK}catclip --hiss${RESET} ${DIM}(delete the rule)${RESET}\n" >&2
      else
        discover_files "$t" "$is_no_ignore" "$discovered_file" "$only_csv"
      fi
    elif [[ "$t" != */* ]]; then
      # Fuzzy search for directory
      local fuzzy_rc=0
      resolved=$(fuzzy_search_dir "$t" "." "$is_no_ignore") || fuzzy_rc=$?

      if (( fuzzy_rc == 0 )); then
        discover_files "$resolved" "$is_no_ignore" "$discovered_file" "$only_csv"
      elif (( fuzzy_rc == 2 )); then
        HAD_FUZZY_FAIL=true  # Had matches but user didn't select
      else
        # No matches at all — smart error
        local known_file=false
        local base_class
        base_class=$(_classify_basename "$t")
        [[ "$base_class" == "text" ]] && known_file=true

        if [[ "$t" == *.* || "$known_file" == true ]]; then
          # Has extension or known basename — definitely a file
          printf "${C_WARN}Warning: '%s' not found at project root.${RESET}\n" "$t" >&2
          printf "\n  ${DIM}To find it in subdirectories:${RESET}\n" >&2
          printf "    ${C_OK}catclip . --only \"%s\"${RESET}         ${DIM}# all matches${RESET}\n" "$t" >&2
          printf "    ${C_OK}catclip src --only \"%s\"${RESET}       ${DIM}# within src/${RESET}\n" "$t" >&2
        else
          # Ambiguous — could be file or directory
          printf "${C_WARN}Warning: No file or directory '%s' found (scope %d).${RESET}\n" "$t" $((idx+1)) >&2
          printf "\n  ${DIM}If it's a file in a subdirectory:${RESET}\n" >&2
          printf "    ${C_OK}catclip . --only \"%s\"${RESET}\n" "$t" >&2
          printf "\n  ${DIM}If it's inside an ignored directory:${RESET}\n" >&2
          printf "    ${C_OK}catclip . --include \"dir/\"${RESET}\n" >&2
        fi
      fi
    else
      local filename="${t##*/}" dir_path="${t%/*}"
      if resolved=$(resolve_chained_path "$dir_path" "$is_no_ignore"); then
        local full="$resolved/$filename"
        if [[ -f "$full" && -r "$full" ]]; then
          local clean="${full#./}"
          if [[ "$is_no_ignore" != true ]] && is_ignored "$clean"; then
            local rule=""
            rule=$(find_matching_rule "$clean") || true
            printf "\n%s\n" "${C_ERR}Error: '${clean}' is ignored by rule '${rule}' in .hiss${RESET}" >&2
            printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"%s\"${RESET}\n" "$rule" >&2
            printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
          else
            is_text_file "$full" && echo "$clean" >> "$discovered_file"
          fi
        elif [[ -d "$full" ]]; then
          if [[ "$is_no_ignore" != true ]] && is_dir_blocked "$full"; then
            local dirname="${full%/}"; dirname="${dirname##*/}"
            printf "\n%s\n" "${C_ERR}Error: '${full#./}' is ignored by .hiss${RESET}" >&2
            printf "\n  ${DIM}To include it this run:${RESET}   ${C_OK}catclip . --include \"${dirname}/\"${RESET}\n" >&2
            printf "  ${DIM}To include everything:${RESET}   ${C_OK}catclip . --include \"*\"${RESET}\n" >&2
            printf "  ${DIM}To remove permanently:${RESET}   ${C_OK}catclip --hiss${RESET} ${DIM}(delete the rule)${RESET}\n" >&2
          else
            discover_files "$full" "$is_no_ignore" "$discovered_file" "$only_csv"
          fi
        else
          printf "${C_WARN}Warning: Target '%s' not found (scope %d).${RESET}\n" "$t" $((idx+1)) >&2
        fi
      else
        printf "${C_WARN}Warning: Target '%s' not found (scope %d).${RESET}\n" "$t" $((idx+1)) >&2
      fi
    fi
  done

  # ── --changed filter ──
  # [Point 6] Include staged + unstaged + untracked regardless of HEAD.
  if [[ "$is_changed" == true ]]; then
    if [[ "$IS_GIT" == true ]]; then
      local changed_file
      changed_file=$(mktmp)

      local has_head=false
      git rev-parse --verify HEAD >/dev/null 2>&1 && has_head=true
      if [[ "$has_head" == true ]]; then
        { git diff --name-only HEAD
          git diff --name-only --cached
          git ls-files --others --exclude-standard
        } 2>/dev/null | sort -u > "$changed_file"
      else
        { git diff --name-only --cached
          git diff --name-only
          git ls-files --others --exclude-standard
        } 2>/dev/null | sort -u > "$changed_file"
      fi

      local filtered
      filtered=$(mktmp)
      comm -12 <(sort -u "$discovered_file") "$changed_file" > "$filtered"
      cat "$filtered" > "$discovered_file"
    else
      printf "${C_WARN}Warning: --changed requires a git repo (scope %d).${RESET}\n" $((idx+1)) >&2
      printf "  ${DIM}This directory is not inside a git repository.${RESET}\n" >&2
    fi
  fi

  # ── Filter pipeline ──
  sort -u "$discovered_file" \
    | if [[ "$is_no_ignore" != true && "$IS_GIT" == true && "$HAS_GITIGNORE" == true ]]; then
        batch_git_filter
      else
        cat
      fi \
    | single_pass_filter "$is_no_ignore" "$only_csv" \
    | if [[ -n "$contains_pattern" ]]; then
        local contains_in contains_out
        contains_in=$(mktmp)
        contains_out=$(mktmp)
        cat > "$contains_in"
        if [[ -s "$contains_in" ]]; then
          tr '\n' '\0' < "$contains_in" \
            | xargs -0 grep -lE -- "$contains_pattern" 2>/dev/null \
            > "$contains_out" || true
          cat "$contains_out"
        fi
      else
        cat
      fi

  # ── Restore original blocklist ──
  ignore_dirs=( ${saved_ignore_dirs[@]+"${saved_ignore_dirs[@]}"} )
  ignore_files=( ${saved_ignore_files[@]+"${saved_ignore_files[@]}"} )
  build_ignore_patterns
}

get_scope_label() {
  local idx="$1"
  local t="${SCOPE_TARGETS[$idx]}"
  [[ -z "$t" ]] && t="."
  local desc="${C_DIR}${t//,/, }${RESET}"
  local flags=""

  [[ "${SCOPE_CHANGED[$idx]}" == true ]] && flags="${flags} ${C_GIT}--changed${RESET}"
  local o="${SCOPE_ONLY[$idx]}"
  [[ -n "$o" ]] && flags="${flags} ${C_OK}--only ${o//,/, }${RESET}"
  local sk="${SCOPE_SKIP[$idx]}"
  [[ -n "$sk" ]] && flags="${flags} ${C_WARN}--exclude ${sk}${RESET}"
  local fi_="${SCOPE_FORCE[$idx]}"
  [[ -n "$fi_" ]] && flags="${flags} ${C_OK}--include ${fi_}${RESET}"
  [[ "${SCOPE_NO_IGNORE[$idx]}" == true ]] && flags="${flags} ${C_ERR}--include \"*\"${RESET}"
  local ct="${SCOPE_CONTAINS[$idx]}"
  [[ -n "$ct" ]] && flags="${flags} ${C_OK}--contains ${ct}${RESET}"

  [[ -n "$flags" ]] && desc="$desc ${DIM}(${flags# })${RESET}"
  echo "$desc"
}

# ==============================================================================
# HISS MANAGEMENT
# ==============================================================================

open_hiss() {
  ensure_config
  local editor="${VISUAL:-${EDITOR:-nano}}"
  if ! command -v "${editor%% *}" &>/dev/null; then
    editor="nano"
    if ! command -v nano &>/dev/null; then
      printf "%s\n" "${C_ERR}Error: No editor found. Set \$EDITOR or install nano.${RESET}" >&2
      exit 1
    fi
  fi
  printf "%s\n" "${DIM}Opening $(short_path "$GLOBAL_HISS") in ${editor%% *}...${RESET}" >&2
  $editor "$GLOBAL_HISS"
}

# ==============================================================================
# MAIN
# ==============================================================================

main() {
  IS_GIT=false
  HAS_GITIGNORE=false
  GIT_ROOT=""
  if [[ "$HAS_GIT" == true ]]; then
    if GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null); then
      IS_GIT=true
      [[ -f "$GIT_ROOT/.gitignore" ]] && HAS_GITIGNORE=true
    fi
  fi

  ensure_config
  load_ignores

  # No-op now (is_ignored uses arrays directly), but called by
  # evaluate_scope after --include and --exclude modify the blocklist.
  build_ignore_patterns

  # ── Arg parsing ──
  # [Point 9] Scope accumulator state is global, not local to main.
  # close_scope() is a nested function that mutates these — using globals
  # makes the mutation explicit and survives refactoring.
  local skip_confirm=false print_content=false no_tree=false preview=false
  local any_no_ignore=false any_changed=false

  # Flush accumulated scope state into the parallel scope arrays.
  close_scope() {
    # Flush if we have targets OR any modifier was set (implicit "." target)
    local _has_modifiers=false
    if [[ "$_cur_changed" == true || "$_cur_no_ignore" == true || -n "$_cur_contains" ]] \
       || (( ${#_cur_only[@]} > 0 || ${#_cur_skip[@]} > 0 || ${#_cur_force[@]} > 0 )); then
      _has_modifiers=true
    fi

    if (( ${#_cur_targets[@]} > 0 )) || [[ "$_has_modifiers" == true ]]; then

      local t_str="" o_str="" s_str="" f_str="" sep=""
      if (( ${#_cur_targets[@]} > 0 )); then
        local t; for t in "${_cur_targets[@]}"; do t_str="${t_str}${sep}${t}"; sep=","; done
      else
        t_str="."
      fi
      sep=""
      local p; for p in ${_cur_only[@]+"${_cur_only[@]}"}; do o_str="${o_str}${sep}${p}"; sep=","; done
      sep=""
      for p in ${_cur_skip[@]+"${_cur_skip[@]}"}; do s_str="${s_str}${sep}${p}"; sep=","; done
      sep=""
      for p in ${_cur_force[@]+"${_cur_force[@]}"}; do f_str="${f_str}${sep}${p}"; sep=","; done

      add_scope "$t_str" "$_cur_changed" "$_cur_no_ignore" "$o_str" "$s_str" "$f_str" "$_cur_contains"

      _cur_targets=(); _cur_changed=false; _cur_no_ignore=false
      _cur_only=(); _cur_skip=(); _cur_force=(); _cur_contains=""
    fi
  }

  while (( $# )); do
    case "$1" in
      -h|--help)      print_help; exit 0 ;;
      --help-all)     print_help_all; exit 0 ;;
      --version|-V)   echo "catclip $VERSION"; exit 0 ;;
      -v|--verbose)   VERBOSE=true; shift ;;
      -q|--quiet)     QUIET=true; shift ;;
      -y|--yes)       skip_confirm=true; shift ;;
      -p|--print)     print_content=true; shift ;;
      -t|--no-tree)   no_tree=true; shift ;;
      --preview)      preview=true; shift ;;
      --hiss) open_hiss; exit 0 ;;
      --hiss-reset)
        local short_hiss
        short_hiss=$(short_path "$GLOBAL_HISS")
        printf "%s\n" "${C_WARN}This will overwrite ${BOLD}${short_hiss}${RESET}${C_WARN} with defaults.${RESET}" >&2
        if prompt_yn "Are you sure? [y/N]" "n"; then
          mkdir -p "$CONFIG_DIR"
          get_default_hiss > "$GLOBAL_HISS"
          printf "%s\n" "${C_OK}Configuration restored.${RESET}" >&2
        else
          printf "Cancelled.\n" >&2
        fi
        exit 0
        ;;
      --changed)
        _cur_changed=true; any_changed=true; shift
        ;;
      --only)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --only requires a pattern.${RESET}" >&2
          printf "  Example: catclip src --only '*.ts'\n" >&2
          exit 2
        fi
        _cur_only+=( "$1" ); shift
        ;;
      --then)
        close_scope; shift
        ;;
      --)
        shift
        while (( $# )); do
          _cur_targets+=( "$1" ); shift
        done
        break
        ;;
      --include)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --include requires a pattern.${RESET}" >&2
          printf "  Example: catclip src --include 'tests/'\n" >&2
          exit 2
        fi
        if [[ "$1" == "*" ]]; then
          _cur_no_ignore=true; any_no_ignore=true
        else
          local _inc_pats=()
          IFS=',' read -ra _inc_pats <<< "$1"
          local _ip; for _ip in "${_inc_pats[@]}"; do
            [[ -n "$_ip" ]] && _cur_force+=( "$_ip" )
          done
        fi
        shift
        ;;
      --exclude)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --exclude requires a pattern.${RESET}" >&2
          printf "  Example: catclip src --exclude '*.test.*'\n" >&2
          exit 2
        fi
        local _exc_pats=()
        IFS=',' read -ra _exc_pats <<< "$1"
        local _ep; for _ep in "${_exc_pats[@]}"; do
          [[ -n "$_ep" ]] && _cur_skip+=( "$_ep" )
        done
        shift
        ;;
      --contains=*)
        printf "%s\n" "${C_ERR}Error: --contains requires a space before the pattern.${RESET}" >&2
        printf "  Use: catclip src --contains 'pattern'\n" >&2
        printf "  Not: catclip src --contains='pattern'\n" >&2
        exit 2
        ;;
      --contains)
        shift
        if (( $# == 0 )); then
          printf "%s\n" "${C_ERR}Error: --contains requires a regex pattern.${RESET}" >&2
          printf "  Example: catclip src --contains 'TODO'\n" >&2
          exit 2
        fi
        if [[ "$1" == *'*'* && "$1" != *'.'* && "$1" != *'['* && "$1" != *'|'* && "$1" != *'\\'* ]]; then
          printf "${C_WARN}Warning: --contains uses regex, not globs. Did you mean '.*' instead of '*'?${RESET}\n" >&2
          printf "  ${DIM}Example: --contains 'use.*Context' (not 'use*Context')${RESET}\n" >&2
        fi
        _cur_contains="$1"; shift
        ;;
      --*)
        printf "%s\n" "${C_ERR}Error: Unknown option '$1'${RESET}" >&2
        printf "  Run 'catclip --help' for available options.\n" >&2
        exit 2
        ;;
      -?*)
        printf "%s\n" "${C_ERR}Error: Unknown option '$1'${RESET}" >&2
        printf "  Run 'catclip --help' for available options.\n" >&2
        exit 2
        ;;
      *)
        _cur_targets+=( "$1" ); shift
        ;;
    esac
  done
  close_scope

  local num_scopes
  num_scopes=$(scope_count)

  if (( num_scopes == 0 )); then
    add_scope "." "false" "false" "" "" "" ""
    num_scopes=1
  fi

  # ── Phase 1: Discovery ──
  local t_discovery
  t_discovery=$(timer_start)
  local list_file
  list_file=$(mktmp)
  local total_files=0

  # Only show scope headers when there are multiple scopes.
  if (( num_scopes > 1 )); then
    info "${BOLD}Scanning...${RESET}\n"
  fi

  local i
  for (( i = 0; i < num_scopes; i++ )); do
    if (( num_scopes > 1 )); then
      local label
      label=$(get_scope_label "$i")
      info "${BOLD}Scope %d:${RESET} %s\n" $((i+1)) "$label"
    fi

    local scope_result
    scope_result=$(mktmp)
    evaluate_scope "$i" > "$scope_result"

    local n
    n=$(count_lines "$scope_result")
    if (( num_scopes > 1 )); then
      info "  ${C_LABEL}%d %s${RESET}\n\n" "$n" "$(plural "$n")"
    fi
    cat "$scope_result" >> "$list_file"
    total_files=$((total_files + n))
  done

  sort -u "$list_file" -o "$list_file"
  local final_count
  final_count=$(count_lines "$list_file")
  # Dedup message is verbose-only — not useful at default verbosity.
  if (( final_count != total_files && num_scopes > 1 )); then
    vlog "Deduplicated: $final_count unique (from $total_files across scopes)"
  fi
  total_files="$final_count"
  timer_end "$t_discovery" "Discovery"

  if (( total_files == 0 )); then
    # Context-aware empty message: distinguish --changed from general empty.
    if [[ "$HAD_FUZZY_FAIL" == true ]]; then
      # User saw matches but didn't select — no diagnostic needed
      :
    elif [[ "$any_changed" == true ]]; then
      printf "%s\n" "${C_WARN}No changed files found.${RESET}" >&2
      printf "  ${DIM}Your working tree may be clean, or the target has no modifications.${RESET}\n" >&2
      printf "  ${DIM}Run without --changed to copy all files.${RESET}\n" >&2
    else
      printf "%s\n" "${C_WARN}No text files found matching your criteria.${RESET}" >&2
      printf "\n  ${DIM}Possible causes:${RESET}\n" >&2
      printf "  ${DIM}  1. Directory is empty or contains only binary files${RESET}\n" >&2
      printf "  ${DIM}  2. All files matched by ignore rules${RESET}\n" >&2
      printf "  ${DIM}  3. Typo in target name${RESET}\n" >&2
      printf "\n  ${DIM}Try: catclip --hiss                   # view/edit ignore rules${RESET}\n" >&2
      printf "  ${DIM}     catclip . --include \"*\"          # disable all ignore rules${RESET}\n" >&2
    fi
    exit 1
  fi

  # ── Phase 2: Size & tokens ──
  local t_size
  t_size=$(timer_start)
  local total_bytes=0
  # For --preview, we need per-file sizes anyway, so capture them here
  # and derive the total — avoids running stat twice.
  local sizes_file=""
  if [[ "$no_tree" == false ]]; then
    sizes_file=$(mktmp)
    if [[ "$PLATFORM" == "macos" ]]; then
      paste "$list_file" <(tr '\n' '\0' < "$list_file" | xargs -0 stat -f %z 2>/dev/null) > "$sizes_file"
    else
      paste "$list_file" <(tr '\n' '\0' < "$list_file" | xargs -0 stat -c %s 2>/dev/null) > "$sizes_file"
    fi
    total_bytes=$(awk -F'\t' '{s+=$2} END {print s+0}' "$sizes_file")
  else
    if [[ "$PLATFORM" == "macos" ]]; then
      total_bytes=$(tr '\n' '\0' < "$list_file" \
        | xargs -0 stat -f %z 2>/dev/null \
        | awk '{s+=$1} END {print s+0}')
    else
      total_bytes=$(tr '\n' '\0' < "$list_file" \
        | xargs -0 stat -c %s 2>/dev/null \
        | awk '{s+=$1} END {print s+0}')
    fi
  fi
  if [[ ! "$total_bytes" =~ ^[0-9]+$ ]]; then
    total_bytes=0
    local s
    while IFS= read -r f; do
      s=$(get_file_size "./$f")
      [[ "$s" =~ ^[0-9]+$ ]] || s=0
      total_bytes=$((total_bytes + s))
    done < "$list_file"
  fi

  local size_tokens human_size est_tokens
  size_tokens=$(format_size_and_tokens "$total_bytes" "$total_files")
  human_size="${size_tokens% *}"
  est_tokens="${size_tokens##* }"
  timer_end "$t_size" "Size calculation"

  local TOKEN_WARN=100000
  local short_config
  short_config=$(short_path "$GLOBAL_HISS")

  # ── Phase 3: Preview ──
  if [[ "$any_no_ignore" == true ]]; then
    info "  ${C_WARN}Safety filters disabled (+\"*\")${RESET}\n"
  elif [[ "$IS_GIT" == true && "$HAS_GITIGNORE" == true ]]; then
    info "  ${C_GIT}Filtered by .gitignore + %s${RESET}\n" "$short_config"
  elif [[ "$IS_GIT" == true ]]; then
    info "  ${C_WARN}Git repo, but no .gitignore; only %s applies.${RESET}\n" "$short_config"
  elif [[ "$HAS_GIT" == false ]]; then
    info "  ${C_WARN}git not installed; only %s applies.${RESET}\n" "$short_config"
  else
    info "  ${C_WARN}Not a git repo; only %s applies.${RESET}\n" "$short_config"
  fi

  local git_status_file=""
  if [[ "$no_tree" == false && "$IS_GIT" == true ]]; then
    git_status_file=$(mktmp)
    # Generate git status map (path\tstatus_letter) — single awk pass.
    git status --porcelain 2>/dev/null | awk '{
      xy = substr($0, 1, 2)
      path = substr($0, 4)
      sub(/\/$/, "", path)
      if (xy == "??")                                   print path "\t?"
      else if (substr(xy,1,1) == "A")                   print path "\tA"
      else if (substr(xy,1,1) != " " && substr(xy,1,1) != "?") print path "\tS"
      else if (substr(xy,2,1) == "M" || substr(xy,2,1) == "D") print path "\tM"
    }' > "$git_status_file"
  fi

  local file_word
  file_word=$(plural "$total_files")
  if [[ "$preview" == true ]]; then
    # --preview: enriched tree (sizes already collected in Phase 2) + git status.
    if [[ "$no_tree" == false ]]; then
      print_tree "$list_file" "$sizes_file" "$git_status_file"
    fi
    printf "\n  ${C_LABEL}%-8s${RESET} ${C_VALUE}%d %s${RESET}\n" "Count:" "$total_files" "$file_word"
    printf "  ${C_LABEL}%-8s${RESET} ${C_VALUE}%s${RESET}\n" "Size:" "$human_size"
    printf "  ${C_LABEL}%-8s${RESET} ${C_VALUE}~%d${RESET}\n" "Tokens:" "$est_tokens"
    exit 0
  else
    if [[ "$no_tree" == false && "$QUIET" != true ]]; then
      print_tree "$list_file" "$sizes_file" "$git_status_file" >&2
    fi
    info "\n  ${C_LABEL}%-8s${RESET} ${C_VALUE}%d %s${RESET}\n" "Count:" "$total_files" "$file_word"
    info "  ${C_LABEL}%-8s${RESET} ${C_VALUE}%s${RESET}\n" "Size:" "$human_size"
    info "  ${C_LABEL}%-8s${RESET} ${C_VALUE}~%d${RESET}\n" "Tokens:" "$est_tokens"
  fi

  if (( est_tokens > TOKEN_WARN )); then
    info "  ${C_WARN}~%d tokens may exceed some LLM context windows.${RESET}\n" "$est_tokens"
  fi

  # ── Confirmation ──
  if [[ "$skip_confirm" == false && "$QUIET" != true ]] && (( est_tokens > TOKEN_WARN )); then
    if ! prompt_yn "${C_PROMPT}Proceed? [y/N]${RESET}" "n"; then
      printf "${C_WARN}Aborted.${RESET}\n" >&2
      exit 0
    fi
  fi

  # ── Phase 4: Build output ──
  local t_build
  t_build=$(timer_start)
  local output_file
  output_file=$(mktmp)

  awk -v warn="$C_WARN" -v rst="$RESET" '
  {
    f = "./" $0
    r = (getline line < f)
    if (r < 0) {
      printf "%sWarning: Cannot read %s. Skipping.%s\n", warn, f, rst > "/dev/stderr"
      next
    }
    print "<file path=\"" $0 "\">"
    if (r > 0) {
      print line
      while ((getline line < f) > 0) print line
    }
    close(f)
    print "</file>\n"
  }' "$list_file" > "$output_file"
  timer_end "$t_build" "Build output"

  # ── Phase 5: Output ──
  local t_clip
  t_clip=$(timer_start)

  # Extract first and last file for the success message.
  local first_file last_file
  first_file=$(head -1 "$list_file")
  last_file=$(tail -1 "$list_file")

  if [[ "$print_content" == true ]]; then
    # --print: write to stdout instead of clipboard.
    cat "$output_file"
  else
    # Default: copy to clipboard.
    if ! detect_clipboard_cmd; then
      printf "${C_ERR}Error: No clipboard tool found.${RESET}\n" >&2
      print_clipboard_install_hint
      printf "\n${DIM}Or use --print to output to stdout:${RESET}\n" >&2
      printf "  catclip --print src > output.txt\n" >&2
      exit 1
    fi

    if "${CLIPBOARD_CMD[@]}" < "$output_file" 2>/dev/null; then
      if (( total_files == 1 )); then
        info "\n${C_OK}Copied${RESET} ${BOLD}%s${RESET} ${C_OK}to clipboard${RESET}\n" "$first_file"
      elif [[ "$first_file" == "$last_file" ]]; then
        info "\n${C_OK}Copied${RESET} ${BOLD}%d %s${RESET} ${C_OK}to clipboard${RESET}\n" "$total_files" "$file_word"
      else
        info "\n${C_OK}Copied${RESET} ${BOLD}%d %s${RESET} ${C_OK}to clipboard${RESET} ${DIM}(%s ... %s)${RESET}\n" \
          "$total_files" "$file_word" "$first_file" "$last_file"
      fi
    else
      printf "\n${C_ERR}Clipboard copy failed.${RESET}\n" >&2
      print_clipboard_install_hint
      printf "\n${DIM}Use --print to output to stdout:${RESET}\n" >&2
      printf "  catclip --print src > output.txt\n" >&2
      exit 1
    fi
  fi
  timer_end "$t_clip" "Output"

  vlog "Total: ${SECONDS}s"
}

# [Point 9] Scope accumulator as globals — close_scope() mutates these.
# Declared here so they're visible to both main() and close_scope().
_cur_targets=()
_cur_changed=false
_cur_no_ignore=false
_cur_only=()
_cur_skip=()
_cur_force=()
_cur_contains=""

main "$@"
