# ==============================================================================
# CLEANUP & TEMP FILE MANAGEMENT
#
# Single temp directory — one rm -rf on exit cleans everything.
# No unbounded array, no per-file tracking.
# ==============================================================================

TMPDIR_CATCLIP=$(mktemp -d) || { printf "Error: Cannot create temp directory.\n" >&2; exit 1; }

mktmp() {
  # mktemp inside the shared temp dir — each call creates a unique file.
  # Cannot use a counter because mktmp is called via $() (subshell).
  mktemp "$TMPDIR_CATCLIP/tmp.XXXXXX"
}

cleanup() {
  [[ -d "$TMPDIR_CATCLIP" ]] && rm -rf "$TMPDIR_CATCLIP"
}
trap cleanup EXIT

# ==============================================================================
# VERBOSE / TIMING
#
# --verbose (-v) enables phase timings and debug output on stderr.
# Uses $SECONDS (built-in, integer resolution) — good enough for phases.
# ==============================================================================

VERBOSE=false
QUIET=false

vlog() {
  [[ "$VERBOSE" == true ]] || return 0
  printf "${C_LABEL}[verbose]${RESET} %s\n" "$*" >&2
}

# Informational output — suppressed by --quiet.
# Errors (exit 1/2) always go to stderr unconditionally.
# SAFETY: First argument is a printf format string. All call sites MUST
# pass a literal format — never user-controlled data as the first arg.
info() {
  [[ "$QUIET" == true ]] && return 0
  printf "$@" >&2
}

timer_start() { echo "$SECONDS"; }

timer_end() {
  local start="$1" label="$2"
  vlog "$label: $((SECONDS - start))s"
}

# ==============================================================================
# UTILITY FUNCTIONS (pure — no global mutation)
# ==============================================================================

prompt_yn() {
  local prompt="$1" default="$2" response=""

  if [[ -t 1 || -t 2 ]]; then
    printf "%s " "$prompt" >&2
    read -r -n 1 response 2>/dev/null || response="$default"
    echo >&2
  elif [[ -r /dev/tty ]]; then
    printf "%s " "$prompt" > /dev/tty 2>/dev/null || true
    read -r -n 1 response < /dev/tty 2>/dev/null || response="$default"
    echo >&2
  else
    response="$default"
  fi

  [[ -z "$response" ]] && response="$default"
  response=$(printf "%s" "$response" | tr 'A-Z' 'a-z')
  [[ "$response" == "y" ]]
}

# [Point 11] Compute human-readable size and token estimate in one awk call.
# Accepts bytes + file count on stdin as "bytes filecount", prints "size tokens".
format_size_and_tokens() {
  awk -v b="$1" -v fc="$2" 'BEGIN {
    b += fc * 30
    tokens = int(b / 4)
    split("B KB MB GB TB", u); i=1
    while (b >= 1024 && i < 5) { b /= 1024; i++ }
    printf "%.2f%s %d\n", b, u[i], tokens
  }'
}

get_file_size() {
  case "$PLATFORM" in
    macos) stat -f %z "$1" 2>/dev/null || echo 0 ;;
    *)     stat -c %s "$1" 2>/dev/null || echo 0 ;;
  esac
}

# [Point 12] Count lines without wc padding issues.
count_lines() {
  awk 'END{print NR}' "$1"
}

# "file" or "files" based on count.
plural() {
  if (( $1 == 1 )); then echo "file"; else echo "files"; fi
}

# Replace $HOME with ~ for display.
short_path() {
  local p="$1"
  case "$p" in "$HOME"*) echo "~${p#"$HOME"}" ;; *) echo "$p" ;; esac
}

# ==============================================================================
# BINARY DETECTION
#
# Three tiers:
#   1. Hard-block extensions (binary — instant reject)
#   2. Known-text extensions (instant accept, skips file(1) entirely)
#   3. file(1) fallback with per-extension cache
#
# For bulk classification, use batch_classify_files (one file(1) fork for all
# unknown-extension files). is_text_file is used for single-file checks only.
# ==============================================================================

# [Point 2] String-match cache instead of parallel array scan.
# O(n) substring search, but avoids per-element loop overhead and
# stays Bash 3.2 compatible (no associative arrays).
_mime_cache=""

_mime_cache_lookup() {
  case " $_mime_cache " in
    *" $1=text "*)   echo "text"; return 0 ;;
    *" $1=binary "*) echo "binary"; return 0 ;;
  esac
  return 1
}

_mime_cache_add() {
  _mime_cache="$_mime_cache $1=$2"
}

# Extension / basename classification strings — single source of truth.
# Space-delimited so bash can match via case " $LIST " in *" $val "*)
# and awk can split() into a hash table for batch classification.
# (Leading spaces on continued lines prevent words from running together
# if an editor auto-trims trailing whitespace).

BINARY_BASENAMES=".ds_store thumbs.db"

TEXT_BASENAMES="makefile gemfile rakefile guardfile vagrantfile berksfile capfile \
 dockerfile containerfile jenkinsfile procfile \
 cmakelists.txt configure configure.ac \
 .gitignore .gitattributes .gitmodules .gitkeep .keep \
 .git-blame-ignore-revs \
 .dockerignore .helmignore .slugignore \
 .vscodeignore .npmignore .eslintignore \
 .editorconfig .eslintrc .prettierrc .stylelintrc \
 .babelrc .npmrc .yarnrc .nvmrc .browserslistrc \
 .flake8 .pylintrc .rubocop.yml \
 .htaccess .mailmap .sequelizerc \
 license licence authors contributors changelog todo \
 codeowners version readme"

BINARY_EXTS="png jpg jpeg gif bmp ico svg webp tif tiff psd xcf heic raw \
 pdf docx doc xlsx xls pptx ppt odt ods odp rtf \
 zip tar gz bz2 xz 7z rar dmg iso img vmdk qcow2 \
 exe dll so dylib a lib o obj pdb \
 class jar war ear pyc pyo pyd wasm beam rlib \
 apk aab ipa msi cab deb rpm \
 pt pth ckpt safetensors onnx gguf h5 pkl parquet arrow \
 mp3 mp4 mov avi mkv webm flv wmv m4a wav flac ogg 3gp \
 ttf otf woff woff2 eot \
 blend glb fbx 3ds \
 db sqlite sqlite3 bin dat hex dump map lockb \
 pack eslintcache \
 icns xpm scpt"

TEXT_EXTS="html htm css scss sass less js jsx mjs cjs ts tsx mts cts \
 json yaml yml xml toml ini cfg conf properties env lock \
 md markdown txt text rst adoc \
 py pyw pyi ipynb rb erb haml pl pm lua sh bash zsh fish bat cmd ps1 psm1 psd1 \
 c cc cpp cxx h hh hpp hxx go rs swift kt kts scala cs fs vb vbs java jsp php sql \
 gd godot shader unity qml \
 mk cmake gradle \
 groovy gvy tf hcl \
 sln csproj vbproj fsproj \
 r rmd clj cljs ex exs erl hrl elm nim zig v d m mm \
 hs lhs jl cl lisp scm ss rkt asm s \
 csv tsv graphql gql proto sol patch diff \
 vim dart vue svelte astro tex j2 ejs hbs mustache liquid pug jade \
 tsbuildinfo info local development production staging test example \
 log out err pid seed snap \
 code-snippets code-workspace tmLanguage \
