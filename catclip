# ==============================================================================
# CLEANUP & TEMP FILE MANAGEMENT
#
# Single temp directory — one rm -rf on exit cleans everything.
# No unbounded array, no per-file tracking.
# ==============================================================================

TMPDIR_CATCLIP=$(mktemp -d) || { printf "Error: Cannot create temp directory.\n" >&2; exit 1; }

mktmp() {
  # mktemp inside the shared temp dir — each call creates a unique file.
  # Cannot use a counter because mktmp is called via $() (subshell).
  mktemp "$TMPDIR_CATCLIP/tmp.XXXXXX"
}

cleanup() {
  [[ -d "$TMPDIR_CATCLIP" ]] && rm -rf "$TMPDIR_CATCLIP"
}
trap cleanup EXIT INT TERM

# ==============================================================================
# VERBOSE / TIMING
#
# --verbose (-v) enables phase timings and debug output on stderr.
# Uses $SECONDS (built-in, integer resolution) — good enough for phases.
# ==============================================================================

VERBOSE=false
QUIET=false
PRINT_CONTENT=false

vlog() {
  [[ "$VERBOSE" == true ]] || return 0
  printf "${C_LABEL}[verbose]${RESET} %s\n" "$*" >&2
}

# Informational output — suppressed by --quiet.
# Errors (exit 1/2) always go to stderr unconditionally.
# SAFETY: First argument is a printf format string. All call sites MUST
# pass a literal format — never user-controlled data as the first arg.
info() {
  [[ "$QUIET" == true ]] && return 0
  printf "$@" >&2
}

warn() {
  [[ "$QUIET" == true ]] && return 0
  printf "$@" >&2
}

is_headless_stdout_mode() {
  [[ "$QUIET" == true && "$PRINT_CONTENT" == true ]]
}

timer_start() { echo "$SECONDS"; }

timer_end() {
  local start="$1" label="$2"
  vlog "$label: $((SECONDS - start))s"
}

# ==============================================================================
# UTILITY FUNCTIONS (pure — no global mutation)
# ==============================================================================

prompt_yn() {
  local prompt="$1" default="$2" response=""
  local tty_fd

  if is_headless_stdout_mode; then
    [[ "$default" == "y" || "$default" == "Y" ]]
    return
  fi

  if [[ -t 0 ]]; then
    printf "%s " "$prompt" >&2
    read -r -n 1 response 2>/dev/null || response="$default"
    echo >&2
  elif exec {tty_fd}<> /dev/tty 2>/dev/null; then
    printf "%s " "$prompt" >&"$tty_fd"
    read -r -n 1 response <&"$tty_fd" 2>/dev/null || response="$default"
    printf "\n" >&"$tty_fd"
    exec {tty_fd}>&-
    exec {tty_fd}<&-
  else
    response="$default"
  fi

  [[ -z "$response" ]] && response="$default"
  response=$(printf "%s" "$response" | tr 'A-Z' 'a-z')
  [[ "$response" == "y" ]]
}

can_prompt_interactively() {
  local tty_fd

  is_headless_stdout_mode && return 1
  [[ -t 0 ]] && return 0
  exec {tty_fd}<> /dev/tty 2>/dev/null || return 1
  exec {tty_fd}>&-
  exec {tty_fd}<&-
  return 0
}

prompt_line() {
  local prompt="$1" response="" tty_fd

  is_headless_stdout_mode && return 1

  if [[ -t 0 ]]; then
    printf "%s" "$prompt" >&2
    read -r response 2>/dev/null || return 1
  elif exec {tty_fd}<> /dev/tty 2>/dev/null; then
    printf "%s" "$prompt" >&"$tty_fd"
    read -r response <&"$tty_fd" 2>/dev/null || {
      exec {tty_fd}>&-
      exec {tty_fd}<&-
      return 1
    }
    exec {tty_fd}>&-
    exec {tty_fd}<&-
  else
    return 1
  fi

  printf "%s" "$response"
}

# [Point 11] Compute human-readable size and token estimate in one awk call.
# Accepts bytes + file count on stdin as "bytes filecount", prints "size tokens".
format_size_and_tokens() {
  awk -v b="$1" -v fc="$2" 'BEGIN {
    b += fc * 30
    tokens = int(b / 4)
    split("B KB MB GB TB", u); i=1
    while (b >= 1024 && i < 5) { b /= 1024; i++ }
    printf "%.2f%s %d\n", b, u[i], tokens
  }'
}

get_file_size() {
  case "$PLATFORM" in
    macos) stat -f %z "$1" 2>/dev/null || echo 0 ;;
    *)     stat -c %s "$1" 2>/dev/null || echo 0 ;;
  esac
}

# [Point 12] Count lines without wc padding issues.
# Returns 0 for empty or missing files (never errors).
count_lines() {
  awk 'END{print NR}' "$1" 2>/dev/null || echo 0
}

# "file" or "files" based on count.
plural() {
  if (( $1 == 1 )); then echo "file"; else echo "files"; fi
}

# Replace $HOME with ~ for display.
short_path() {
  local p="$1"
  case "$p" in "$HOME"*) echo "~${p#"$HOME"}" ;; *) echo "$p" ;; esac
}

# ==============================================================================
# BINARY DETECTION
#
# Three tiers:
#   1. Hard-block extensions (binary — instant reject)
#   2. Known-text extensions (instant accept, skips file(1) entirely)
#   3. file(1) fallback with per-extension cache
#
# For bulk classification, use batch_classify_files (one file(1) fork for all
# unknown-extension files). is_text_file is used for single-file checks only.
# ==============================================================================

# [Point 2] String-match cache instead of parallel array scan.
# O(n) substring search, but avoids per-element loop overhead and
# stays Bash 3.2 compatible (no associative arrays).
_mime_cache=""

_mime_cache_lookup() {
  case " $_mime_cache " in
    *" $1=text "*)   echo "text"; return 0 ;;
    *" $1=binary "*) echo "binary"; return 0 ;;
  esac
  return 1
}

_mime_cache_add() {
  _mime_cache="$_mime_cache $1=$2"
}

# Extension / basename classification strings — single source of truth.
# Space-delimited so bash can match via case " $LIST " in *" $val "*)
# and awk can split() into a hash table for batch classification.
# (Leading spaces on continued lines prevent words from running together
# if an editor auto-trims trailing whitespace).

BINARY_BASENAMES=".ds_store thumbs.db"

TEXT_BASENAMES="makefile gemfile rakefile guardfile vagrantfile berksfile capfile \
 dockerfile containerfile jenkinsfile procfile \
 cmakelists.txt configure configure.ac \
 .gitignore .gitattributes .gitmodules .gitkeep .keep \
 .git-blame-ignore-revs \
 .dockerignore .helmignore .slugignore \
 .vscodeignore .npmignore .eslintignore \
 .editorconfig .eslintrc .prettierrc .stylelintrc \
 .babelrc .npmrc .yarnrc .nvmrc .browserslistrc \
 .flake8 .pylintrc .rubocop.yml \
 .htaccess .mailmap .sequelizerc \
 license licence authors contributors changelog todo \
 codeowners version readme"

BINARY_EXTS="png jpg jpeg gif bmp ico svg webp tif tiff psd xcf heic raw \
 pdf docx doc xlsx xls pptx ppt odt ods odp rtf \
 zip tar gz bz2 xz 7z rar dmg iso img vmdk qcow2 \
 exe dll so dylib a lib o obj pdb \
 class jar war ear pyc pyo pyd wasm beam rlib \
 apk aab ipa msi cab deb rpm \
 pt pth ckpt safetensors onnx gguf h5 pkl parquet arrow \
 mp3 mp4 mov avi mkv webm flv wmv m4a wav flac ogg 3gp \
 ttf otf woff woff2 eot \
 blend glb fbx 3ds \
 db sqlite sqlite3 bin dat hex dump map lockb \
 pack eslintcache \
 icns xpm scpt"

TEXT_EXTS="html htm css scss sass less js jsx mjs cjs ts tsx mts cts \
 json yaml yml xml toml ini cfg conf properties env lock \
 md markdown txt text rst adoc \
 py pyw pyi ipynb rb erb haml pl pm lua sh bash zsh fish bat cmd ps1 psm1 psd1 \
 c cc cpp cxx h hh hpp hxx go rs swift kt kts scala cs fs vb vbs java jsp php sql \
 gd godot shader unity qml \
 mk cmake gradle \
 groovy gvy tf hcl \
 sln csproj vbproj fsproj \
 r rmd clj cljs ex exs erl hrl elm nim zig v d m mm \
 hs lhs jl cl lisp scm ss rkt asm s \
 csv tsv graphql gql proto sol patch diff \
 vim dart vue svelte astro tex j2 ejs hbs mustache liquid pug jade \
 tsbuildinfo info local development production staging test example \
 log out err pid seed snap \
 code-snippets code-workspace tmLanguage \
 desktop template spec ps1xml"

# Extension classification result:
#   "binary" = tier 1 hard block
#   "text"   = tier 2 known text
#   ""       = unknown, needs file(1)
# Both _classify_basename and _classify_ext are ALWAYS called via $()
# (command substitution = subshell). shopt changes die with the subshell,
# so nocasematch cannot leak to the parent. No manual shopt -u needed.

_classify_basename() {
  local base="$1"
  shopt -s nocasematch
  case " $BINARY_BASENAMES " in *" $base "*) echo "binary"; return 0 ;; esac
  case " $TEXT_BASENAMES " in *" $base "*) echo "text"; return 0 ;; esac
}

_classify_ext() {
  local ext="$1"
  [[ -z "$ext" ]] && return 0

  shopt -s nocasematch
  case " $BINARY_EXTS " in *" $ext "*) echo "binary"; return 0 ;; esac
  case " $TEXT_EXTS " in *" $ext "*) echo "text"; return 0 ;; esac

  # nocasematch off for cache lookup — cache keys are verbatim extensions.
  shopt -u nocasematch
  local cached
  if cached=$(_mime_cache_lookup "$ext"); then
    echo "$cached"
    return 0
  fi
}

# Extract extension from a path. Returns "" for extensionless files.
_get_ext() {
  local f="$1"
  local ext="${f##*.}"
  local base="${f##*/}"
  if [[ "$ext" == "$f" || "$ext" == "$base" ]]; then
    echo ""
  else
    echo "$ext"
  fi
}

# Single-file text check. Use batch_classify_files for bulk operations.
is_text_file() {
  local f="$1"
  local ext
  ext=$(_get_ext "$f")
  local class
  class=$(_classify_ext "$ext")

  [[ "$class" == "binary" ]] && return 1
  [[ "$class" == "text" ]] && return 0

  # Extensionless? Try known basename before expensive file(1).
  if [[ -z "$ext" ]]; then
    class=$(_classify_basename "${f##*/}")
    [[ "$class" == "text" ]] && return 0
  fi

  # Tier 3 fallback: file(1)
  local mime
  mime=$(file -b --mime "$f" 2>/dev/null) || return 1

  local result=1 kind=""
  if [[ "$mime" == text/* ]] || [[ "$mime" =~ application/(json|xml|javascript|x-sh|x-yaml) ]]; then
    result=0; kind="text"
  elif [[ "$mime" =~ (utf-16|utf-32|binary) ]]; then
    result=1; kind="binary"
  elif [[ ! -s "$f" ]]; then
    result=0; kind="text"
  fi

  # [Point 2] Use string cache instead of parallel arrays.
  if [[ -n "$kind" && -n "$ext" ]]; then
    _mime_cache_add "$ext" "$kind"
  fi
  return "$result"
}

# Batch classify: reads file paths from $1, writes text file paths to $2.
# Known extensions are resolved inline (fast). Unknown extensions are batched
# into a single file(1) call via xargs (one fork for all of them).
batch_classify_files() {
  local input_file="$1"
  local output_file="$2"
  local unknown_file
  unknown_file=$(mktmp)

  # Pass 1: awk classifies by extension + basename at C speed.
  # Inputs come from git ls-files or find -type f, so files exist.
  # Replaces the per-file bash loop that spawned 2-3 subshells per file.
  awk -v bexts="$BINARY_EXTS" -v texts="$TEXT_EXTS" \
      -v bbases="$BINARY_BASENAMES" -v tbases="$TEXT_BASENAMES" \
      -v unknowns="$unknown_file" '
  BEGIN {
    n = split(bexts, a);  for (i=1;i<=n;i++) be[tolower(a[i])]=1
    n = split(texts, a);  for (i=1;i<=n;i++) te[tolower(a[i])]=1
    n = split(bbases, a); for (i=1;i<=n;i++) bb[tolower(a[i])]=1
    n = split(tbases, a); for (i=1;i<=n;i++) tb[tolower(a[i])]=1
  }
  {
    path = $0
    # extract basename
    n = split(path, segs, "/")
    base = segs[n]
    # extract extension
    # if base does not contain a dot, m=1
    # if base is .eslint-ignore, m=2 and dots[1] is empty
    m = split(base, dots, ".")
    if (m > 1) {
      if (m == 2 && dots[1] == "") ext = ""
      else ext = tolower(dots[m])
    } else {
      ext = ""
    }

    # classify by extension
    if (ext != "" && (ext in be)) next
    if (ext != "" && (ext in te)) {
      sub(/^\.\//, "", path); print path; next
    }

    # classify by basename
    lbase = tolower(base)
    if (lbase in bb) next
    if (lbase in tb) { sub(/^\.\//, "", path); print path; next }

    # unknown — queue for file(1)
    print $0 > unknowns
  }' < "$input_file" >> "$output_file"

  # Pass 2: single file(1) invocation for all unknowns.
  # Uses file(1) with filenames in output (-F separator) so each output
  # line is self-describing. Avoids the fragile paste trick which can
  # desync if filenames contain the delimiter character.
  if [[ -s "$unknown_file" ]]; then
    local mime_output sep_str
    mime_output=$(mktmp)
    sep_str='<:CATCLIP:>'

    tr '\n' '\0' < "$unknown_file" \
      | xargs -0 file -F "$sep_str" --mime 2>/dev/null \
      > "$mime_output"

    # [Point 14] Declare loop variables before the loop.
    local batch_count=0 fpath mime_str is_text line ext
    while IFS= read -r line; do
      fpath="${line%%"$sep_str"*}"
      mime_str="${line#*"$sep_str"}"
      # file(1) pads output with spaces to align strings; strip ALL leading spaces
      mime_str="${mime_str#"${mime_str%%[! ]*}"}"
      ext=$(_get_ext "$fpath")
      is_text=false

      if [[ "$mime_str" == text/* ]] || [[ "$mime_str" =~ application/(json|xml|javascript|x-sh|x-yaml) ]]; then
        is_text=true
      elif [[ ! -s "$fpath" ]]; then
        is_text=true
      fi

      # [Point 2] Use string cache.
      if [[ -n "$ext" ]]; then
        if [[ "$is_text" == true ]]; then
          _mime_cache_add "$ext" "text"
        elif [[ "$mime_str" =~ (utf-16|utf-32|binary) ]]; then
          _mime_cache_add "$ext" "binary"
        fi
      fi

      [[ "$is_text" == true ]] && echo "${fpath#./}" >> "$output_file"
      batch_count=$((batch_count + 1))
    done < "$mime_output"

    vlog "Batch file(1): classified $batch_count unknown-extension files"
    if [[ "$VERBOSE" == true ]]; then
      local _uf
      while IFS= read -r _uf; do
        printf "[verbose]   %s\n" "${_uf#./}" >&2
      done < "$unknown_file"
    fi
  fi
}

# ==============================================================================
# CONFIG LOADING
# ==============================================================================

ignore_dirs=()
ignore_files=()

parse_hiss() {
  local source="$1" line
  [[ -r "$source" ]] || return 0

  while IFS= read -r line; do
    # Strip comments and whitespace
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" ]] && continue

    # Directory (trailing /)
    if [[ "$line" == */ ]]; then
      ignore_dirs+=( "${line%/}" )
    else
      ignore_files+=( "$line" )
    fi
  done < "$source"
}

load_ignores() {
  ignore_dirs=()
  ignore_files=()
  parse_hiss "$GLOBAL_HISS"
}

ensure_config() {
  [[ -f "$GLOBAL_HISS" ]] && return 0
  mkdir -p "$CONFIG_DIR"
  get_default_hiss > "$GLOBAL_HISS"
}

# ==============================================================================
# IGNORE SYSTEM
#
# Global .hiss + .gitignore.
# Batch git check-ignore via --stdin (one fork, not N).
# is_ignored() loops over ignore_files/ignore_dirs arrays directly.
# ==============================================================================

# is_ignored() checks file/dir arrays directly. bash case-statement
# alternation (|) does not work from variable expansion, so we loop.
# The arrays are small (tens of entries), so this is fast enough.
#
# Safety: case glob matching is exact for fixed strings — only * ? [ ]
# are special. A .hiss entry "log" matches filename "log" but NOT
# "catalog" (unlike the substring bug fixed in fuzzy_search_dir).

is_ignored() {
  local filepath="$1"
  local filename="${filepath##*/}"
  local p d

  for p in ${ignore_files[@]+"${ignore_files[@]}"}; do
    case "$filename" in $p) return 0 ;; esac
    case "$filepath" in $p) return 0 ;; esac
  done
  for d in ${ignore_dirs[@]+"${ignore_dirs[@]}"}; do
    case "$filepath" in "$d"/*|*"/$d"/*) return 0 ;; esac
  done
  return 1
}

# Check if a directory name is in the ignore_dirs blocklist.
is_dir_blocked() {
  local dirname="$1"
  dirname="${dirname%/}"
  dirname="${dirname##*/}"
  local d
  for d in ${ignore_dirs[@]+"${ignore_dirs[@]}"}; do
    [[ "$d" == "$dirname" ]] && return 0
  done
  return 1
}

# Find which .hiss rule matched a path, for error messages.
# Returns the rule string, or "" if no match.
find_matching_rule() {
  local filepath="$1"
  local filename="${filepath##*/}"
  local p d
  for p in ${ignore_files[@]+"${ignore_files[@]}"}; do
    case "$filename" in $p) echo "$p"; return 0 ;; esac
    case "$filepath" in $p) echo "$p"; return 0 ;; esac
  done
  for d in ${ignore_dirs[@]+"${ignore_dirs[@]}"}; do
    case "$filepath" in "$d"/*|*"/$d"/*) echo "$d/"; return 0 ;; esac
  done
  return 1
}

warned_dir_syntax_patterns=$'\n'
AUTO_CONFIRM=false

has_glob_chars() {
  case "$1" in
    *'*'*|*'?'*|*'['*) return 0 ;;
    *) return 1 ;;
  esac
}

looks_like_directory_pattern() {
  local pat="$1"
  local d

  [[ -n "$pat" ]] || return 1
  [[ -d "$pat" ]] && return 0

  for d in ${ignore_dirs[@]+"${ignore_dirs[@]}"}; do
    [[ "$d" == "$pat" ]] && return 0
  done

  # Cheap heuristic only: bare names without a path separator or extension are
  # commonly intended as directory rules (platform, common, node_modules,
  # tests). Avoid scanning the tree here; this warning must stay effectively
  # free on large repos.
  [[ "$pat" != */* && "$pat" != *.* ]] || return 1
  [[ "$pat" =~ ^[a-z0-9][a-z0-9_-]*$ ]] || return 1
  return 0

}

warn_if_missing_dir_slash() {
  local flag_name="$1"
  local pat="$2"

  [[ -n "$pat" ]] || return 0
  [[ "$pat" == */ ]] && return 0
  has_glob_chars "$pat" && return 0

  looks_like_directory_pattern "$pat" || return 0

  local warn_key="${flag_name}:${pat}"
  case "$warned_dir_syntax_patterns" in
    *$'\n'"$warn_key"$'\n'*) return 0 ;;
  esac
  warned_dir_syntax_patterns="${warned_dir_syntax_patterns}${warn_key}"$'\n'

  warn "%s\n" "${C_WARN}Warning: ${flag_name} pattern '${pat}' looks like a directory name.${RESET}"
  warn "  ${DIM}Directory rules require a trailing slash:${RESET} ${C_OK}%s/${RESET}\n" "$pat"
  warn "  ${DIM}Without '/', it is treated as a file pattern.${RESET}\n"

  if [[ "$AUTO_CONFIRM" != true ]] && can_prompt_interactively; then
    if ! prompt_yn "${C_PROMPT}Continue with file-pattern semantics? [y/N]${RESET}" "n"; then
      printf "${C_WARN}Aborted.${RESET}\n" >&2
      exit 0
    fi
  fi
}

# Apply --include patterns: remove matching entries from in-memory blocklist.
# Called per-scope before discovery. Modifies ignore_dirs/ignore_files globals.
apply_force_include() {
  local force_csv="$1"
  local patterns=()
  IFS=',' read -ra patterns <<< "$force_csv"

  local pat new_files=() new_dirs=() p d keep
  for pat in "${patterns[@]}"; do
    if [[ "$pat" == */ ]]; then
      # Directory rule: remove from ignore_dirs
      local dirname="${pat%/}"
      new_dirs=()
      for d in ${ignore_dirs[@]+"${ignore_dirs[@]}"}; do
        [[ "$d" == "$dirname" ]] || new_dirs+=( "$d" )
      done
      ignore_dirs=( ${new_dirs[@]+"${new_dirs[@]}"} )
    else
      warn_if_missing_dir_slash "--include" "$pat"
      # File pattern: remove exact match from ignore_files
      new_files=()
      for p in ${ignore_files[@]+"${ignore_files[@]}"}; do
        [[ "$p" == "$pat" ]] || new_files+=( "$p" )
      done
      ignore_files=( ${new_files[@]+"${new_files[@]}"} )
    fi
  done
}

# Apply --exclude patterns: add new entries to in-memory blocklist.
# Called per-scope before discovery. Modifies ignore_dirs/ignore_files globals.
apply_skip_patterns() {
  local skip_csv="$1"
  local patterns=()
  IFS=',' read -ra patterns <<< "$skip_csv"

  local pat
  for pat in "${patterns[@]}"; do
    if [[ "$pat" == */ ]]; then
      ignore_dirs+=( "${pat%/}" )
    else
      warn_if_missing_dir_slash "--exclude" "$pat"
      ignore_files+=( "$pat" )
    fi
  done
}

# [Point 3] Reads paths from stdin, writes NON-ignored paths to stdout.
# Uses process substitution to avoid extra temp files for sorting.
batch_git_filter() {
  local tmp_all tmp_ignored
  tmp_all=$(mktmp)
  tmp_ignored=$(mktmp)

  cat > "$tmp_all"
  [[ -s "$tmp_all" ]] || return 0

  git check-ignore --stdin < "$tmp_all" > "$tmp_ignored" 2>/dev/null || true

  if [[ ! -s "$tmp_ignored" ]]; then
    cat "$tmp_all"
  else
    comm -23 <(sort "$tmp_all") <(sort "$tmp_ignored")
  fi
}

# ==============================================================================
# PATH RESOLUTION
# ==============================================================================

contains_parent_traversal() {
  # Match ".." as a path component: standalone, leading, trailing, or mid-path.
  # Must not false-positive on legitimate names like "foo.." or "..bar".
  [[ "$1" == .. || "$1" == ../* || "$1" == */../* || "$1" == */.. ]]
}

fuzzy_search_dir() {
  local name="$1"
  local base="${2:-.}"
  local no_ignore="${3:-false}"
  local found=()

  local prune_opts=()
  if [[ "$no_ignore" == false ]] && (( ${#ignore_dirs[@]} > 0 )); then
    local d
    for d in "${ignore_dirs[@]}"; do
      prune_opts+=( -name "$d" -prune -o )
    done
  fi

  local all_matches=()
  while IFS= read -r -d '' d; do
    all_matches+=( "$d" )
  done < <(find "$base" ${prune_opts[@]+"${prune_opts[@]}"} -type d -not -type l -name "*${name}*" -print0 2>/dev/null)

  if (( ${#all_matches[@]} == 0 )); then
    return 1
  fi

  # Batch git check-ignore instead of one fork per directory.
  if [[ "$IS_GIT" == true && "$no_ignore" == false ]]; then
    local ignored_list d d_pat nl_ignored
    ignored_list=$(printf "%s\n" "${all_matches[@]}" \
      | git check-ignore --stdin 2>/dev/null) || true
    if [[ -z "$ignored_list" ]]; then
      found=( "${all_matches[@]}" )
    else
      # Exact line membership: avoid substring false positives (a vs ab).
      nl_ignored=$'\n'"$ignored_list"$'\n'
      for d in "${all_matches[@]}"; do
        # Escape shell pattern chars in candidate path for safe case matching.
        d_pat="$d"
        d_pat="${d_pat//\\/\\\\}"
        d_pat="${d_pat//\*/\\*}"
        d_pat="${d_pat//\?/\\?}"
        d_pat="${d_pat//\[/\\[}"
        d_pat="${d_pat//\]/\\]}"
        case "$nl_ignored" in
          *$'\n'"$d_pat"$'\n'*) ;; # ignored by git
          *) found+=( "$d" ) ;;
        esac
      done
    fi
  else
    found=( "${all_matches[@]}" )
  fi

  if (( ${#found[@]} == 0 )); then
    return 1
  fi

  if (( ${#found[@]} == 1 )); then
    echo "${found[0]}"
    return 0
  fi

  if is_headless_stdout_mode; then
    return 3  # ambiguous in machine mode; caller should raise a real error
  fi

  printf "%s\n" "${BOLD}Multiple matches for '$name':${RESET}" >&2
  local i
  for i in "${!found[@]}"; do
    printf "  ${BOLD}%2d)${RESET} ${C_DIR}%s${RESET}\n" $((i+1)) "${found[i]}" >&2
  done
  if (( ${#found[@]} > 5 )); then
    printf "\n%s\n" "${C_WARN}Tip:${RESET} ${DIM}Too many matches. Narrow with path segments:${RESET}" >&2
    printf "  ${C_OK}catclip parent/${name}${RESET}\n" >&2
  fi
  local c
  c=$(prompt_line "Choose [1-${#found[@]}]: ") || return 2
  if [[ "$c" =~ ^[0-9]+$ ]] && (( c >= 1 && c <= ${#found[@]} )); then
    echo "${found[c-1]}"
    return 0
  fi
  printf "%s\n" "${C_ERR}Invalid selection.${RESET}" >&2
  return 2  # 2 = had matches, selection failed (caller should not print hints)
}

resolve_chained_path() {
  local path="$1"
  local no_ignore="${2:-false}"
  local current="."
  local segments=()

  IFS='/' read -ra segments <<< "$path"
  local seg resolved fuzzy_rc
  for seg in "${segments[@]}"; do
    if [[ -d "$current/$seg" ]]; then
      current="$current/$seg"
    elif resolved=$(fuzzy_search_dir "$seg" "$current" "$no_ignore"); then
      current="$resolved"
    else
      fuzzy_rc=$?
      if (( fuzzy_rc == 2 )); then
        return 1
      elif (( fuzzy_rc == 3 )); then
        printf "%s\n" "${C_ERR}Error: Multiple directories match '$seg' in $current.${RESET}" >&2
        printf "  Use a more specific path segment to disambiguate.\n" >&2
        return 1
      fi
      printf "%s\n" "${C_ERR}Error: No directory matching '$seg' found in $current${RESET}" >&2
      printf "  Check the spelling, or use --hiss to see if it's excluded.\n" >&2
      return 1
    fi
  done
  echo "$current"
}

# ==============================================================================
# FILE DISCOVERY
#
# Central engine: given a directory, produce a list of text file paths.
# Uses batch_classify_files for efficient binary detection (one file(1) fork).
# Git-aware: uses 'git ls-files' when in a repo (handles .gitignore for free).
# ==============================================================================

# [Point 7] Consistent boolean convention: always compare with == true.
discover_files() {
  local dir="$1"
  local no_ignore="$2"
  local out_file="$3"
  local only_csv="${4:-}"
  local clean="${dir#./}"

  if [[ "$IS_GIT" == true && "$no_ignore" != true ]]; then
    # Use git ls-files (fast index read for tracked files) but pre-filter
    # by ignore_dirs via awk before the expensive batch_classify_files.
    # ignore_dirs is the big win — drops node_modules/ etc. (100k+ files).
    # ignore_files are handled later in single_pass_filter on the small list.
    local filtered
    filtered=$(mktmp)

    if (( ${#ignore_dirs[@]} > 0 )); then
      local dirs_joined=""
      local sep="" d
      for d in "${ignore_dirs[@]}"; do
        dirs_joined="${dirs_joined}${sep}${d}"
        sep="|"
      done
      git ls-files --cached --others --exclude-standard -- "$clean" 2>/dev/null \
        | awk -v dirs="$dirs_joined" '
          BEGIN { n = split(dirs, d, "|") }
          {
            dominated = 0
            for (i = 1; i <= n; i++) {
              # matches d[i]/ at start or /d[i]/ anywhere
              if (index($0, d[i] "/") == 1 || index($0, "/" d[i] "/") > 0) {
                dominated = 1; break
              }
            }
            if (!dominated) print
          }' > "$filtered"
    else
      git ls-files --cached --others --exclude-standard -- "$clean" 2>/dev/null > "$filtered"
    fi

    batch_classify_files "$filtered" "$out_file"
  else
    local prune_opts=()
    if [[ "$no_ignore" != true ]] && (( ${#ignore_dirs[@]} > 0 )); then
      local d
      for d in "${ignore_dirs[@]}"; do
        prune_opts+=( -name "$d" -prune -o )
      done
    fi

    # Optimization: when no_ignore=true and only_csv has simple *.ext globs,
    # push them into find -name to avoid discovering everything then filtering.
    local name_opts=()
    if [[ "$no_ignore" == true && -n "$only_csv" ]]; then
      local all_simple=true pat
      local only_pats_arr=()
      IFS=',' read -ra only_pats_arr <<< "$only_csv"
      for pat in "${only_pats_arr[@]}"; do
        if [[ "$pat" == \*.* && "$pat" != */* && "$pat" != *\** && "${pat:1}" == ".${pat#*.}" ]]; then
          : # simple *.ext pattern
        elif [[ "$pat" == \*.* && "$pat" != */* ]]; then
          : # *.ext pattern (may have multiple dots)
        else
          all_simple=false; break
        fi
      done
      if [[ "$all_simple" == true ]]; then
        local first=true
        name_opts+=( '(' )
        for pat in "${only_pats_arr[@]}"; do
          [[ "$first" == true ]] && first=false || name_opts+=( -o )
          name_opts+=( -name "$pat" )
        done
        name_opts+=( ')' )
      fi
    fi

    local raw_list
    raw_list=$(mktmp)
    if (( ${#name_opts[@]} > 0 )); then
      find "$dir" ${prune_opts[@]+"${prune_opts[@]}"} -type f -not -type l "${name_opts[@]}" -print 2>/dev/null > "$raw_list"
    else
      find "$dir" ${prune_opts[@]+"${prune_opts[@]}"} -type f -not -type l -print 2>/dev/null > "$raw_list"
    fi

    if [[ "$no_ignore" != true ]]; then
      local filtered
      filtered=$(mktmp)
      local f
      while IFS= read -r f; do
        [[ -r "$f" ]] || continue
        is_ignored "${f#./}" || echo "$f"
      done < "$raw_list" > "$filtered"
      batch_classify_files "$filtered" "$out_file"
    else
      batch_classify_files "$raw_list" "$out_file"
    fi
  fi
}

# ==============================================================================
# PATTERN MATCHING
# ==============================================================================

matches_pattern() {
  local filepath="$1" pattern="$2"
  local filename="${filepath##*/}"
  case "$filename" in $pattern) return 0 ;; esac
  case "$filepath" in $pattern) return 0 ;; esac
  return 1
}

path_has_dir() {
  local filepath="$1" dirname="$2"
  [[ -n "$dirname" ]] || return 1
  case "$filepath" in "$dirname"/*|*"/$dirname"/*) return 0 ;; esac
  return 1
}

# ==============================================================================
# SNIPPET EXTRACTION
#
# For each match of PATTERN in FILE, expands up/down to blank-line boundaries
# and emits a <file path="..." snippet="START-END"> block.
# Overlapping or identical blocks are deduplicated.
# ==============================================================================

extract_snippets() {
  local filepath="$1" pattern="$2"
  local fullpath="./$filepath"

  # Collect matching line numbers (1-indexed) into a temp file.
  # awk -v cannot carry newlines, so we pass them via a file instead.
  local ml_file
  ml_file=$(mktmp)
  grep -nE -- "$pattern" "$fullpath" 2>/dev/null | cut -d: -f1 > "$ml_file" || true
  [[ -s "$ml_file" ]] || return 0

  awk -v ml_file="$ml_file" -v filepath="$filepath" '
  BEGIN {
    # Load matched line numbers from file.
    while ((getline ln < ml_file) > 0) matched[ln+0] = 1
    close(ml_file)
  }
  { lines[NR] = $0 }
  END {
    total = NR
    for (m in matched) {
      m = m + 0
      # Walk up to previous blank line (or start of file).
      start = m
      while (start > 1 && lines[start-1] != "") start--
      # Walk down to next blank line (or end of file).
      end = m
      while (end < total && lines[end+1] != "") end++
      # Emit block once per unique range.
      key = start ":" end
      if (!(key in emitted)) {
        emitted[key] = 1
        print "<file path=\"" filepath "\" snippet=\"" start "-" end "\">"
        for (i = start; i <= end; i++) print lines[i]
        print "</file>\n"
      }
    }
  }' "$fullpath"
}

# ==============================================================================
# DIFF EXTRACTION
#
# Emits the unified git diff for a file, choosing the right git command based
# on which filter flags were active in the scope.
# Untracked files have no diff — they are emitted with type="untracked" (full content).
# Tracked files are tagged: type="staged-diff", type="unstaged-diff", or type="diff".
# ==============================================================================

extract_diff() {
  local filepath="$1"
  local want_staged="$2"    # true | false
  local want_unstaged="$3"  # true | false
  local fullpath="./$filepath"

  # Detect untracked: git ls-files returns nothing for unknown paths.
  local is_tracked
  is_tracked=$(git ls-files -- "$filepath" 2>/dev/null)
  if [[ -z "$is_tracked" ]]; then
    # Untracked file — no diff possible, emit full content.
    printf '<file path="%s" type="untracked">\n' "$filepath"
    cat "$fullpath" 2>/dev/null
    printf '</file>\n\n'
    return
  fi

  # Choose the diff command and type label based on active filters.
  local diff_output diff_type
  if [[ "$want_staged" == true && "$want_unstaged" != true ]]; then
    diff_output=$(git diff --cached -- "$filepath" 2>/dev/null)
    diff_type="staged-diff"
  elif [[ "$want_unstaged" == true && "$want_staged" != true ]]; then
    diff_output=$(git diff -- "$filepath" 2>/dev/null)
    diff_type="unstaged-diff"
  else
    # Both (or --changed with no sub-filter) — diff vs HEAD.
    diff_output=$(git diff HEAD -- "$filepath" 2>/dev/null)
    diff_type="diff"
  fi

  [[ -z "$diff_output" ]] && return  # clean file, skip

  printf '<file path="%s" type="%s">\n' "$filepath" "$diff_type"
  printf '%s\n' "$diff_output"
  printf '</file>\n\n'
}

# ==============================================================================
# LANDMARK DIRECTORY DETECTOR
# ==============================================================================
# Identifies directories whose basename appears at multiple distinct paths.
# These always get a full-path annotation in the tree (name collision).
# Input:  $1 = sorted list of file paths (one per line)
# Output: landmark directories (one per line) to stdout
detect_landmarks() {
  local list_file="$1"
  awk '
  {
    n = split($0, parts, "/")
    dir = ""
    for (i = 1; i < n; i++) {
      dir = (dir == "" ? parts[i] : dir "/" parts[i])
      bname = parts[i]
      bkey = bname SUBSEP dir
      if (!(bkey in seen)) {
        seen[bkey] = 1
        name_count[bname]++
      }
      all_dirs[dir] = 1
    }
  }
  END {
    for (dir in all_dirs) {
      n = split(dir, p, "/")
      if (name_count[p[n]] > 1) print dir
    }
  }' "$list_file"
}

# ==============================================================================
# TREE PRINTER
# ==============================================================================

# [Point 13] Use "k in last" instead of hardcoded depth limit.
# Enhanced tree for --preview and regular mode: shows file sizes (heatmap) and git status.
# Reads from:
#   $1 = list_file (sorted paths)
#   $2 = sizes_file (path\tsize_in_bytes, one per line)
#   $3 = git_status_file (path\tstatus_letter, one per line; may be empty)
print_tree() {
  local list_file="$1" sizes_file="$2" git_status_file="${3:-}" mode_file="${4:-}" landmarks_file="${5:-}"
  sort "$list_file" | awk \
    -v dcol="$C_DIR" -v rst="$RESET" -v tcol="$C_TREE" \
    -v dim="$DIM" -v cwarn="$C_WARN" -v cerr="$C_ERR" \
    -v cok="$C_OK" -v cgit="$C_GIT" \
    -v sizes_f="$sizes_file" -v git_f="$git_status_file" \
    -v mode_f="$mode_file" \
    -v lm_f="$landmarks_file" \
    -F/ '
  BEGIN {
    # Load per-file sizes into sizes[] array.
    while ((getline line < sizes_f) > 0) {
      split(line, a, "\t")
      sizes[a[1]] = a[2] + 0
    }
    close(sizes_f)
    # Load git status into gstat[] array.
    if (git_f != "") {
      while ((getline line < git_f) > 0) {
        split(line, a, "\t")
        gstat[a[1]] = a[2]
      }
      close(git_f)
    }
    # Load output mode tags into omode[] array.
    # Priority: "diff only" > "snippet only" (matches Phase 4 output logic).
    if (mode_f != "") {
      while ((getline line < mode_f) > 0) {
        split(line, a, "\t")
        if (a[1] in omode && omode[a[1]] == "diff only") continue
        omode[a[1]] = a[2]
      }
      close(mode_f)
    }
    # Load landmark directories (name collisions).
    if (lm_f != "") {
      while ((getline line < lm_f) > 0) {
        landmarks[line] = 1
      }
      close(lm_f)
    }
    # Line counter for periodic path anchoring (every 24 lines).
    line_count = 0
  }
  {
    path = $0
    # Print directory prefixes (unchanged from print_tree).
    for (i = 1; i < NF; i++) {
      if ($i != last[i]) {
        for (j = 1; j < i; j++) printf tcol "│   " rst
        printf (i == 1 ? "" : tcol "├── " rst)
        # Build accumulated directory path for landmark check.
        accum = ""
        for (ai = 1; ai <= i; ai++) {
          accum = (accum == "" ? $ai : accum "/" $ai)
        }
        printf dcol $i "/" rst
        # Root directories (depth 1) never get hints — the path just
        # repeats the name. Collisions and periodic anchors only apply
        # at depth > 1 where the full path adds information.
        if (i > 1 && ((accum in landmarks) || line_count >= 24)) {
          printf " " dim "(" accum "/" ")" rst
          line_count = 0
        }
        printf "\n"
        line_count++
        last[i] = $i
        for (k = i+1; k in last; k++) delete last[k]
      }
    }
    # Print tree connector + filename.
    for (j = 1; j < NF; j++) printf tcol "│   " rst
    printf tcol "├── " rst
    printf "%s", $NF

    # Append size with heatmap color.
    if (path in sizes) {
      b = sizes[path]
      # Format size: B, KB, or MB.
      if (b < 1024) {
        sz = sprintf("%dB", b)
      } else if (b < 1048576) {
        sz = sprintf("%.1fKB", b / 1024)
      } else {
        sz = sprintf("%.1fMB", b / 1048576)
      }
      # Heatmap: <40KB grey, <200KB yellow, else red.
      if (b < 40000) {
        printf " " dim "(%s)" rst, sz
      } else if (b < 200000) {
        printf " " cwarn "(%s)" rst, sz
      } else {
        printf " " cerr "(%s)" rst, sz
      }
    }

    # Append git status marker.
    if (path in gstat) {
      s = gstat[path]
      if (s == "M") {
        printf " " cwarn "[M]" rst
      } else if (s == "S") {
        printf " " cok "[S]" rst
      } else if (s == "?") {
        printf " " cgit "[?]" rst
      } else if (s == "A") {
        printf " " cok "[A]" rst
      }
    }

    # Append output mode tag (partial-output indicators only).
    # Skip for untracked files in diff mode — they get full content, not a patch.
    if (path in omode) {
      if (!(omode[path] == "diff only" && gstat[path] == "?")) {
        printf " " cgit "[" omode[path] "]" rst
      }
    }

    printf "\n"
    line_count++
    delete last[NF]
  }'
}

