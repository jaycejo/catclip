#!/usr/bin/env bash
# ==============================================================================
# catclip — Context Gatherer for LLMs
#
# Copies code files to clipboard with "<file path=\"path\">" tags for AI prompts.
# Filters secrets, binaries, and build artifacts by default.
#
# EXIT CODES:
#   0  Success
#   1  Runtime error (no files found, clipboard failure, config corruption)
#   2  Usage error (bad arguments, invalid paths)
#
# DESIGN:
#   1. Safety First    — Secrets (.env, *.pem) and junk (node_modules) excluded
#   2. Git-Aware       — Uses git ls-files + .gitignore when in a repo
#   3. Zero Deps       — Only bash, awk, find, file, git (optional)
#   4. Bash 3.2        — macOS ships old bash; no associative arrays, no mapfile
#   5. Fast            — Extension allow/block lists, batch file(1), batch git ops
# ==============================================================================

# NOTE: set -e interacts poorly with functions that intentionally return
# non-zero (e.g. _mime_cache_lookup). Such calls MUST remain inside
# conditionals (if/||/&&) to prevent silent exits. Test after refactoring.
set -euo pipefail

# IFS=$'\n\t' globally: split on newline/tab only, never space.
# This preserves filenames with spaces everywhere. Functions that need
# different splitting use inline IFS= or IFS=',' on the read call.
IFS=$'\n\t'

# Save original arguments for exec-on-retry (config reset path).
ORIG_ARGS=("$@")

# ==============================================================================
# PLATFORM & PREREQUISITES
# ==============================================================================

export TERM="${TERM:-xterm-256color}"

detect_platform() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)
      if [[ -f /proc/version ]] && grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi
      ;;
    CYGWIN*|MINGW*|MSYS*) echo "wsl" ;;
    *) echo "unknown" ;;
  esac
}

PLATFORM="$(detect_platform)"

for cmd in find mktemp awk file; do
  if ! command -v "$cmd" &>/dev/null; then
    printf "Error: '%s' is required but not found in PATH.\n" "$cmd" >&2
    printf "  This is a core system tool. Check your PATH or install it.\n" >&2
    exit 1
  fi
done

HAS_GIT=false
command -v git &>/dev/null && HAS_GIT=true

# ==============================================================================
# VERSION
# ==============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PREFIX_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SHARE_DIR="$PREFIX_DIR/share/catclip"
VERSION="dev"
if [[ -f "$SHARE_DIR/VERSION" ]]; then
  VERSION="$(tr -d ' \t\r\n' < "$SHARE_DIR/VERSION")"
elif [[ -f "$SCRIPT_DIR/VERSION" ]]; then
  VERSION="$(tr -d ' \t\r\n' < "$SCRIPT_DIR/VERSION")"
fi
if [[ -n "${CATCLIP_VERSION:-}" ]]; then
  VERSION="$CATCLIP_VERSION"
fi

# ==============================================================================
# COLORS
#
# Semantic names — never raw escape codes in logic.
# Respects NO_COLOR (https://no-color.org) and non-TTY stderr.
# ==============================================================================

setup_colors() {
  if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 2 ]]; then
    RESET="" BOLD="" DIM=""
    C_OK="" C_ERR="" C_WARN="" C_DIR=""
    C_LABEL="" C_VALUE="" C_TREE="" C_PROMPT="" C_GIT=""
  else
    RESET=$'\033[0m'
    BOLD=$'\033[1m'
    DIM=$'\033[2m'
    C_OK=$'\033[32m'
    C_ERR=$'\033[31m'
    C_WARN=$'\033[33m'
    C_DIR=$'\033[1;34m'
    C_LABEL=$'\033[90m'
    C_VALUE=$'\033[1m'
    C_TREE=$'\033[90m'
    C_PROMPT=$'\033[36m'
    C_GIT=$'\033[35m'
  fi
}
setup_colors

# ==============================================================================
